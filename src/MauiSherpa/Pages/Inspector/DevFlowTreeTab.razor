    // --- Gradient editor helpers ---

    private void InitGradientStops(BrushInfo info)
    {
        gradientStops.Clear();
        selectedStopIndex = null;
        gradientAngle = 90;

        if (info.Type == "linear" || info.Type == "radial")
        {
            // Parse stops from CSS gradient string
            var css = info.CssPreview;
            var stopsStr = css;
            var parenStart = css.IndexOf('(');
            var parenEnd = css.LastIndexOf(')');
            if (parenStart >= 0 && parenEnd > parenStart)
                stopsStr = css[(parenStart + 1)..parenEnd];

            // Extract angle for linear
            if (info.Type == "linear")
            {
                var angleMatch = System.Text.RegularExpressions.Regex.Match(stopsStr, @"(\d+(?:\.\d+)?)\s*deg");
                if (angleMatch.Success && double.TryParse(angleMatch.Groups[1].Value, out var deg))
                    gradientAngle = deg;
            }

            // Extract color stops: #hex pct%, rgba(...) pct%, colorname pct%
            var stopMatches = System.Text.RegularExpressions.Regex.Matches(stopsStr,
                @"(#[0-9A-Fa-f]{3,8}|rgba?\([^)]+\)|[a-zA-Z]+)\s*(\d+(?:\.\d+)?)%");
            foreach (System.Text.RegularExpressions.Match m in stopMatches)
            {
                var colorStr = m.Groups[1].Value.Trim();
                var offset = double.Parse(m.Groups[2].Value) / 100.0;
                var opacity = 1.0;

                // Parse rgba opacity
                var rgbaMatch = System.Text.RegularExpressions.Regex.Match(colorStr, @"rgba?\(\s*(\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)");
                if (rgbaMatch.Success)
                {
                    var r = int.Parse(rgbaMatch.Groups[1].Value);
                    var g = int.Parse(rgbaMatch.Groups[2].Value);
                    var b = int.Parse(rgbaMatch.Groups[3].Value);
                    colorStr = $"#{r:X2}{g:X2}{b:X2}";
                    if (rgbaMatch.Groups[4].Success && double.TryParse(rgbaMatch.Groups[4].Value, System.Globalization.CultureInfo.InvariantCulture, out var a))
                        opacity = a;
                }

                // Skip non-color tokens like "circle", "deg" numbers
                if (colorStr.Equals("circle", StringComparison.OrdinalIgnoreCase)
                    || colorStr.Equals("ellipse", StringComparison.OrdinalIgnoreCase))
                    continue;

                gradientStops.Add(new GradientStop { Color = colorStr.StartsWith("#") ? colorStr : NamedColorToHex(colorStr), Offset = offset, Opacity = opacity });
            }

            // Fallback: extract just hex colors without percentages
            if (gradientStops.Count < 2)
            {
                gradientStops.Clear();
                var hexMatches = System.Text.RegularExpressions.Regex.Matches(stopsStr, @"#[0-9A-Fa-f]{3,8}");
                for (int i = 0; i < hexMatches.Count; i++)
                {
                    gradientStops.Add(new GradientStop
                    {
                        Color = hexMatches[i].Value,
                        Offset = hexMatches.Count > 1 ? (double)i / (hexMatches.Count - 1) : 0,
                        Opacity = 1
                    });
                }
            }

            // Ensure at least 2 stops
            if (gradientStops.Count < 2)
            {
                gradientStops = new List<GradientStop>
                {
                    new() { Color = "#ff0000", Offset = 0, Opacity = 1 },
                    new() { Color = "#0000ff", Offset = 1, Opacity = 1 }
                };
            }

            selectedStopIndex = 0;
        }
    }

    private string DetectEditBrushType()
    {
        var v = editValue.Trim();
        if (v.StartsWith("linear-gradient", StringComparison.OrdinalIgnoreCase)) return "linear";
        if (v.StartsWith("radial-gradient", StringComparison.OrdinalIgnoreCase)) return "radial";
        if (gradientStops.Count >= 2) return "linear"; // default for gradient mode
        return "solid";
    }

    private string BuildGradientCss(string type)
    {
        if (gradientStops.Count == 0) return editValue;
        var sorted = gradientStops.OrderBy(s => s.Offset).ToList();
        var stops = string.Join(", ", sorted.Select(s =>
        {
            var c = s.Opacity < 1
                ? $"rgba({HexToRgb(s.Color)}, {s.Opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})"
                : s.Color;
            return $"{c} {(s.Offset * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}%";
        }));
        return type == "radial"
            ? $"radial-gradient(circle, {stops})"
            : $"linear-gradient({gradientAngle.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}deg, {stops})";
    }

    private string BuildLinearStopsCss()
    {
        if (gradientStops.Count == 0) return "#888, #ccc";
        var sorted = gradientStops.OrderBy(s => s.Offset).ToList();
        return string.Join(", ", sorted.Select(s =>
        {
            var c = s.Opacity < 1
                ? $"rgba({HexToRgb(s.Color)}, {s.Opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})"
                : s.Color;
            return $"{c} {(s.Offset * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}%";
        }));
    }

    private static string HexToRgb(string hex)
    {
        hex = hex.TrimStart('#');
        if (hex.Length == 3) hex = $"{hex[0]}{hex[0]}{hex[1]}{hex[1]}{hex[2]}{hex[2]}";
        if (hex.Length >= 6)
        {
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return $"{r}, {g}, {b}";
        }
        return "0, 0, 0";
    }

    private static string NamedColorToHex(string name) => name.ToLowerInvariant() switch
    {
        "red" => "#ff0000", "green" => "#008000", "blue" => "#0000ff",
        "white" => "#ffffff", "black" => "#000000", "yellow" => "#ffff00",
        "cyan" => "#00ffff", "magenta" => "#ff00ff", "orange" => "#ffa500",
        "purple" => "#800080", "pink" => "#ffc0cb", "gray" or "grey" => "#808080",
        "transparent" => "#00000000",
        _ => "#888888"
    };

    // --- Brush value parsing ---

    private record BrushInfo(string Type, string CssPreview, string DisplayText);

    private static BrushInfo ParseBrushValue(string value)
    {
        if (string.IsNullOrEmpty(value) || value == "null")
            return new BrushInfo("none", "transparent", "none");

        var trimmed = value.Trim();

        // CSS gradient syntax (what BrushTypeConverter accepts)
        if (trimmed.StartsWith("linear-gradient", StringComparison.OrdinalIgnoreCase))
            return new BrushInfo("linear", trimmed, TruncateBrush(trimmed));

        if (trimmed.StartsWith("radial-gradient", StringComparison.OrdinalIgnoreCase))
            return new BrushInfo("radial", trimmed, TruncateBrush(trimmed));

        // MAUI LinearGradientBrush ToString format
        if (trimmed.Contains("LinearGradientBrush", StringComparison.OrdinalIgnoreCase))
            return new BrushInfo("linear", ParseMauiGradientToCss(trimmed, "linear"), TruncateBrush(trimmed));

        if (trimmed.Contains("RadialGradientBrush", StringComparison.OrdinalIgnoreCase))
            return new BrushInfo("radial", ParseMauiGradientToCss(trimmed, "radial"), TruncateBrush(trimmed));

        // SolidColorBrush ToString or plain color
        if (trimmed.Contains("SolidColorBrush", StringComparison.OrdinalIgnoreCase))
        {
            var colorMatch = System.Text.RegularExpressions.Regex.Match(trimmed, @"Color\s*=\s*(\S+)");
            var color = colorMatch.Success ? colorMatch.Groups[1].Value.TrimEnd(']', '}', ')') : trimmed;
            return new BrushInfo("solid", MauiColorToCss(color), color);
        }

        // Hex color or named color → solid brush
        if (trimmed.StartsWith("#") || trimmed.StartsWith("Color ") || char.IsLetter(trimmed[0]))
            return new BrushInfo("solid", MauiColorToCss(trimmed), trimmed);

        return new BrushInfo("unknown", "transparent", trimmed);
    }

    private static string ParseMauiGradientToCss(string value, string type)
    {
        // MAUI gradient ToString formats:
        // 1) Contains hex colors: "#FF0000", "#0000FF"
        // 2) Contains Color descriptors: "Color [A=1, R=1, G=0, B=0, ...]" with Offset values
        // 3) Just the type name: "Microsoft.Maui.Controls.LinearGradientBrush"

        var stops = new List<(string hex, double offset)>();

        // Try to extract "Color [A=..., R=..., G=..., B=...]" with optional "Offset=..." nearby
        var colorDescMatches = System.Text.RegularExpressions.Regex.Matches(value,
            @"Color\s*\[\s*A=([^,\]]+),\s*R=([^,\]]+),\s*G=([^,\]]+),\s*B=([^,\]]+)");
        var offsetMatches = System.Text.RegularExpressions.Regex.Matches(value,
            @"Offset=([0-9.]+)");

        if (colorDescMatches.Count >= 2)
        {
            for (int i = 0; i < colorDescMatches.Count; i++)
            {
                var m = colorDescMatches[i];
                if (double.TryParse(m.Groups[2].Value, System.Globalization.CultureInfo.InvariantCulture, out var r) &&
                    double.TryParse(m.Groups[3].Value, System.Globalization.CultureInfo.InvariantCulture, out var g) &&
                    double.TryParse(m.Groups[4].Value, System.Globalization.CultureInfo.InvariantCulture, out var b))
                {
                    var hex = $"#{(int)(r * 255):X2}{(int)(g * 255):X2}{(int)(b * 255):X2}";
                    var offset = i < offsetMatches.Count && double.TryParse(offsetMatches[i].Groups[1].Value, System.Globalization.CultureInfo.InvariantCulture, out var o)
                        ? o : (colorDescMatches.Count > 1 ? (double)i / (colorDescMatches.Count - 1) : 0);
                    stops.Add((hex, offset));
                }
            }
        }

        // Fallback: extract hex colors
        if (stops.Count < 2)
        {
            stops.Clear();
            var hexMatches = System.Text.RegularExpressions.Regex.Matches(value, @"#[0-9A-Fa-f]{6,8}");
            for (int i = 0; i < hexMatches.Count; i++)
            {
                var offset = hexMatches.Count > 1 ? (double)i / (hexMatches.Count - 1) : 0;
                stops.Add((hexMatches[i].Value, offset));
            }
        }

        if (stops.Count >= 2)
        {
            var cssStops = string.Join(", ", stops.Select(s => $"{s.hex} {s.offset * 100:F0}%"));
            return type == "linear"
                ? $"linear-gradient(90deg, {cssStops})"
                : $"radial-gradient(circle, {cssStops})";
        }

        // Final fallback
        return type == "linear"
            ? "linear-gradient(90deg, #888, #ccc)"
            : "radial-gradient(circle, #888, #ccc)";
    }

    private static string TruncateBrush(string text)
        => text.Length <= 40 ? text : text[..40] + "…";

