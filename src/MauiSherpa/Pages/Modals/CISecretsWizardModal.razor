    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge != null)
        {
            bridge.SubmitRequested -= OnSubmitRequested;
            bridge.BackRequested -= OnBackRequested;
            bridge.NextRequested -= OnNextRequested;
        }
    }
