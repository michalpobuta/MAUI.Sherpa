        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "prop-row editable");
        __builder.AddAttribute(2, "onclick", EventCallback.Factory.Create<MouseEventArgs>(this, () => StartEditing(prop.Name, prop.Value)));

        __builder.OpenElement(3, "span");
        __builder.AddAttribute(4, "class", "prop-key");
        __builder.AddContent(5, prop.Name);
        __builder.CloseElement();

        if (editingProperty == prop.Name)
        {
            __builder.OpenElement(6, "input");
            __builder.AddAttribute(7, "type", "number");
            __builder.AddAttribute(8, "class", "prop-edit-input");
            __builder.AddAttribute(9, "step", prop.Meta.NumStep.ToString());
            if (prop.Meta.NumMin.HasValue) __builder.AddAttribute(10, "min", prop.Meta.NumMin.Value.ToString());
            if (prop.Meta.NumMax.HasValue) __builder.AddAttribute(11, "max", prop.Meta.NumMax.Value.ToString());
            __builder.AddAttribute(12, "value", editValue);
            __builder.AddAttribute(13, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, (e) => { editValue = e.Value?.ToString() ?? ""; }));
            __builder.AddAttribute(14, "onkeydown", EventCallback.Factory.Create<KeyboardEventArgs>(this, OnEditKeyDown));
            __builder.AddAttribute(15, "onfocusout", EventCallback.Factory.Create(this, OnEditBlur));
            __builder.AddElementReferenceCapture(16, (r) => editInput = r);
            __builder.CloseElement();
        }
        else
        {
            __builder.OpenElement(17, "span");
            __builder.AddAttribute(18, "class", "prop-value");
            __builder.AddContent(19, prop.Value);
            __builder.CloseElement();

            if (hasDefault && !isDefault)
            {
                __builder.OpenElement(19, "button");
                __builder.AddAttribute(20, "class", "btn-reset");
                __builder.AddAttribute(21, "title", $"Reset to {prop.Meta.DefaultValue}");
                __builder.AddAttribute(22, "onclick", EventCallback.Factory.Create<MouseEventArgs>(this, async (e) =>
                {
                    editingProperty = prop.Name;
                    editValue = prop.Meta.DefaultValue!;
                    await CommitEdit();
                }));
                __builder.OpenElement(23, "i");
                __builder.AddAttribute(24, "class", "fas fa-undo");
                __builder.CloseElement();
                __builder.CloseElement();
            }
        }

        __builder.CloseElement(); // div.prop-row
    };

