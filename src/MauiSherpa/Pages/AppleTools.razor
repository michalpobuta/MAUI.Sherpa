@page "/apple-tools"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.ViewModels
@inject AppleToolsViewModel ViewModel
@inject IPlatformService Platform
@inject IAlertService AlertService

<h1><i class="fab fa-apple"></i> @ViewModel.Title</h1>

@if (!Platform.IsMacCatalyst && !Platform.IsMacOS)
{
    <div class="not-supported">
        <div class="warning-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <h2>macOS Only</h2>
        <p>Apple development tools management requires macOS with Xcode installed.</p>
    </div>
}
else
{
    <div class="status-bar">
        <span class="status-label">Status:</span>
        <span class="status-text">@ViewModel.StatusMessage</span>
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" @onclick="RefreshInstalled" disabled="@ViewModel.IsLoading">
            <i class="fas fa-sync-alt"></i> @(ViewModel.IsLoading ? "Loading..." : "Refresh")
        </button>
    </div>

    <div class="tabs">
        <button class="tab @(activeTab == "installed" ? "active" : "")" @onclick="@(() => SwitchTab("installed"))">
            <i class="fas fa-hdd"></i> Installed (@ViewModel.InstalledXcodes.Count)
        </button>
        <button class="tab @(activeTab == "available" ? "active" : "")" @onclick="@(() => SwitchTab("available"))">
            <i class="fas fa-cloud-download-alt"></i> Available
            @if (ViewModel.AvailableReleases.Count > 0)
            {
                <span class="tab-count">(@ViewModel.FilteredAvailableReleases.Count)</span>
            }
        </button>
    </div>

    @if (activeTab == "installed")
    {
        @if (ViewModel.IsLoading && ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Discovering Xcode Installations</div>
                <div class="loading-description">Scanning /Applications for Xcode bundles...</div>
            </div>
        }
        else if (ViewModel.InstalledXcodes.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                <h3>No Xcode Installations Found</h3>
                <p>Install Xcode from the Mac App Store or download from the Available tab.</p>
            </div>
        }
        else
        {
            <div class="xcode-list">
                @foreach (var xcode in ViewModel.InstalledXcodes)
                {
                    <div class="xcode-card @(xcode.IsSelected ? "selected" : "")">
                        <div class="xcode-card-icon">
                            <i class="fas fa-hammer"></i>
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @xcode.Version
                                @if (xcode.IsSelected)
                                {
                                    <span class="badge badge-active"><i class="fas fa-check"></i> Active</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @xcode.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-folder"></i> @xcode.Path</span>
                            </div>
                        </div>
                        <div class="xcode-card-actions">
                            @if (!xcode.IsSelected)
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => SelectXcode(xcode)">
                                    <i class="fas fa-check-circle"></i> Select
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (activeTab == "available")
    {
        <div class="available-controls">
            <label class="toggle-label">
                <input type="checkbox" @bind="showBetas" @bind:event="oninput" />
                <span>Show Betas &amp; RCs</span>
            </label>
            @if (ViewModel.IsLoadingAvailable)
            {
                <span class="loading-indicator"><i class="fas fa-spinner fa-spin"></i> Fetching releases...</span>
            }
        </div>

        @if (ViewModel.IsLoadingAvailable && filteredReleases.Count == 0)
        {
            <div class="loading-state">
                <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                <div class="loading-title">Fetching Available Releases</div>
                <div class="loading-description">Querying xcodereleases.com...</div>
            </div>
        }
        else if (filteredReleases.Count > 0)
        {
            <div class="results-info">Showing @filteredReleases.Count releases</div>
            <div class="xcode-list">
                @foreach (var release in filteredReleases)
                {
                    var installed = ViewModel.IsInstalled(release);
                    <div class="xcode-card @(installed ? "installed" : "")">
                        <div class="xcode-card-icon">
                            @if (release.IsBeta)
                            {
                                <i class="fas fa-flask"></i>
                            }
                            else
                            {
                                <i class="fas fa-hammer"></i>
                            }
                        </div>
                        <div class="xcode-card-info">
                            <div class="xcode-card-title">
                                Xcode @release.Version
                                @if (release.IsBeta)
                                {
                                    <span class="badge badge-beta">Beta</span>
                                }
                                @if (installed)
                                {
                                    <span class="badge badge-installed"><i class="fas fa-check"></i> Installed</span>
                                }
                            </div>
                            <div class="xcode-card-details">
                                <span class="detail-item"><i class="fas fa-code-branch"></i> Build @release.BuildNumber</span>
                                <span class="detail-item"><i class="fas fa-calendar"></i> @release.ReleaseDate.ToString("MMM d, yyyy")</span>
                                @if (!string.IsNullOrEmpty(release.MinimumMacOSVersion))
                                {
                                    <span class="detail-item"><i class="fas fa-desktop"></i> macOS @release.MinimumMacOSVersion+</span>
                                }
                            </div>
                            @if (release.Sdks.Count > 0)
                            {
                                <div class="xcode-card-sdks">
                                    @foreach (var sdk in release.Sdks.Take(5))
                                    {
                                        <span class="sdk-tag">@sdk.Name @sdk.Version</span>
                                    }
                                    @if (release.Sdks.Count > 5)
                                    {
                                        <span class="sdk-tag more">+@(release.Sdks.Count - 5) more</span>
                                    }
                                </div>
                            }
                            @if (release.Compilers.Count > 0)
                            {
                                <div class="xcode-card-compilers">
                                    @foreach (var compiler in release.Compilers)
                                    {
                                        <span class="compiler-tag">@compiler.Name @compiler.Version</span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="xcode-card-actions">
                            @if (!string.IsNullOrEmpty(release.ReleaseNotesUrl))
                            {
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenUrl(release.ReleaseNotesUrl)">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                            }
                            @if (!installed && !string.IsNullOrEmpty(release.DownloadUrl))
                            {
                                <button class="btn btn-sm btn-outline" @onclick="() => OpenUrl(release.DownloadUrl)">
                                    <i class="fas fa-download"></i> Download
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

}

<style>
    h1 {
        margin-bottom: 1.25rem;
        font-size: 1.75rem;
        color: var(--text-primary);
    }

    .not-supported {
        text-align: center;
        padding: 3.75rem 1.25rem;
        background: var(--status-error-bg);
        border-radius: 0.75rem;
        border: 1px solid var(--accent-danger);
    }
    .not-supported .warning-icon { font-size: 48px; margin-bottom: 1rem; color: var(--accent-warning); }
    .not-supported .warning-icon i { font-size: 48px; }
    .not-supported h2 { color: var(--accent-danger); margin-bottom: 0.5rem; }
    .not-supported p { color: var(--text-muted); }

    .status-bar {
        background: var(--card-bg);
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .status-label { font-weight: 600; color: var(--text-primary); }
    .status-text { color: var(--text-secondary); flex: 1; }

    .auth-status {
        font-size: 0.8125rem;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        margin-left: auto;
    }
    .auth-status.signed-in { color: var(--accent-success); }
    .auth-status .btn-link {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 0.75rem;
        text-decoration: underline;
        padding: 0;
    }
    .auth-status .btn-link:hover { color: var(--accent-danger); }

    .toolbar {
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Tabs */
    .tabs {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1rem;
        border-bottom: 2px solid var(--border-color);
    }
    .tab {
        padding: 0.75rem 1.25rem;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--text-muted);
        font-size: 0.875rem;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .tab:hover { color: var(--accent-primary); }
    .tab.active {
        color: var(--accent-primary);
        border-bottom-color: var(--accent-primary);
        font-weight: 600;
    }
    .tab-count { opacity: 0.7; }

    /* Loading & Empty States */
    .loading-state, .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        background: var(--card-bg);
        border-radius: var(--card-radius);
        border: 1px solid var(--border-color);
    }
    .loading-spinner { font-size: 2rem; color: var(--accent-primary); margin-bottom: 1rem; }
    .loading-title, .empty-state h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
    .loading-description, .empty-state p { color: var(--text-muted); font-size: 0.875rem; }
    .empty-icon { font-size: 2.5rem; color: var(--text-muted); margin-bottom: 1rem; opacity: 0.5; }

    /* Xcode Cards */
    .xcode-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .xcode-card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--card-radius);
        transition: all 0.15s ease;
    }
    .xcode-card:hover { border-color: var(--accent-primary); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .xcode-card.selected { border-color: var(--accent-success); background: var(--status-success-bg); }
    .xcode-card.installed { border-left: 3px solid var(--accent-success); }

    .xcode-card-icon {
        font-size: 1.5rem;
        color: var(--accent-primary);
        padding-top: 0.125rem;
        flex-shrink: 0;
        width: 2rem;
        text-align: center;
    }
    .xcode-card.selected .xcode-card-icon { color: var(--accent-success); }

    .xcode-card-info { flex: 1; min-width: 0; }

    .xcode-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .xcode-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 0.375rem;
        font-size: 0.8125rem;
        color: var(--text-muted);
    }
    .detail-item { display: flex; align-items: center; gap: 0.375rem; }
    .detail-item i { font-size: 0.6875rem; opacity: 0.7; }

    .xcode-card-sdks, .xcode-card-compilers {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: 0.5rem;
    }

    .sdk-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: var(--bg-tertiary);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
    }
    .sdk-tag.more { font-style: italic; opacity: 0.7; }

    .compiler-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        border-radius: 0.25rem;
        background: rgba(66, 153, 225, 0.1);
        color: var(--accent-primary);
        border: 1px solid rgba(66, 153, 225, 0.2);
    }

    .xcode-card-actions {
        display: flex;
        gap: 0.375rem;
        flex-shrink: 0;
        align-items: flex-start;
    }

    /* Badges */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        font-weight: 600;
        border-radius: 1rem;
    }
    .badge-active {
        background: var(--accent-success);
        color: white;
    }
    .badge-beta {
        background: rgba(237, 137, 54, 0.15);
        color: var(--accent-warning);
        border: 1px solid rgba(237, 137, 54, 0.3);
    }
    .badge-installed {
        background: rgba(72, 187, 120, 0.15);
        color: var(--accent-success);
        border: 1px solid rgba(72, 187, 120, 0.3);
    }

    /* Buttons */
    .btn-sm {
        padding: 0.375rem 0.75rem;
        font-size: 0.8125rem;
    }
    .btn-outline {
        background: transparent;
        border: 1px solid var(--accent-primary);
        color: var(--accent-primary);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    .btn-outline:hover { background: var(--accent-primary); color: white; }

    .btn-ghost {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    .btn-ghost:hover { color: var(--accent-primary); border-color: var(--accent-primary); }

    .btn-secondary {
        background: var(--bg-tertiary);
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        cursor: pointer;
        font-size: 0.875rem;
    }
    .btn-secondary:hover { background: var(--border-color); }

    /* Available Controls */
    .available-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        background: var(--card-bg);
        border-radius: 0.5rem;
        border: 1px solid var(--border-color);
    }

    .toggle-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        cursor: pointer;
    }
    .toggle-label input[type="checkbox"] { accent-color: var(--accent-primary); }

    .loading-indicator {
        font-size: 0.8125rem;
        color: var(--text-muted);
    }

    .results-info {
        font-size: 0.8125rem;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
    }
</style>

@code {
    private string activeTab = "installed";
    private bool showBetas;
    private bool hasInitialized;

    private IReadOnlyList<XcodeRelease> filteredReleases =>
        showBetas
            ? ViewModel.AvailableReleases.Take(50).ToList()
            : ViewModel.AvailableReleases.Where(r => !r.IsBeta).Take(50).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!hasInitialized)
        {
            hasInitialized = true;
            await ViewModel.LoadInstalledAsync();
        }
    }

    private async Task RefreshInstalled()
    {
        await ViewModel.LoadInstalledAsync();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "available" && ViewModel.AvailableReleases.Count == 0)
        {
            await ViewModel.LoadAvailableAsync();
        }
    }

    private async Task SelectXcode(XcodeInstallation xcode)
    {
        await ViewModel.SelectXcodeAsync(xcode);
        StateHasChanged();
    }

    private void OpenUrl(string url)
    {
        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo("open", url) { UseShellExecute = false };
            System.Diagnostics.Process.Start(psi);
        }
        catch { }
    }
}
