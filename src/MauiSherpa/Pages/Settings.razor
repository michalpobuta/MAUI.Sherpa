            effectiveJdkPath = await JdkSettings.GetEffectiveJdkPathAsync();
            editableJdkPath = effectiveJdkPath ?? "";
            await AlertService.ShowToastAsync("JDK path reset to default");
        }
        catch (Exception ex)
        {
            await AlertService.ShowAlertAsync("Error", $"Failed to reset JDK path: {ex.Message}");
        }
        finally
        {
            isLoadingJdk = false;
            StateHasChanged();
        }
    }

