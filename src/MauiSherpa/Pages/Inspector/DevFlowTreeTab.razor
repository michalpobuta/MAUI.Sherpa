    private async Task UpdateOverlayAsync()
    {
        overlayStyle = null;
        if (selectedElement == null || screenshotData == null) return;

        var absBounds = GetAbsoluteBounds(selectedElement);
        if (absBounds == null)
        {
            if (hitTestDebug) { hitTestDebugInfo += $" | overlay: no absBounds (B={selectedElement.Bounds != null} WB={selectedElement.WindowBounds != null})"; StateHasChanged(); }
            return;
        }

        try
        {
            // Get actual image rendering dimensions via JS
            var dims = await JS.InvokeAsync<ImageDimensions>("eval",
                "(function() { var img = document.querySelector('.screenshot-img');" +
                "if (!img) return null;" +
                "var r = img.getBoundingClientRect();" +
                "return { width: r.width, height: r.height, naturalWidth: img.naturalWidth, naturalHeight: img.naturalHeight, left: r.left, top: r.top }; })()");

            if (dims == null || dims.NaturalWidth <= 0 || dims.NaturalHeight <= 0) return;

            var (windowWidth, windowHeight, dpiScale) = GetWindowMetrics(dims.NaturalWidth, dims.NaturalHeight);
            if (windowWidth <= 0 || windowHeight <= 0) return;

            // Account for object-fit: contain letterboxing
            var imgAspect = dims.NaturalWidth / dims.NaturalHeight;
            var boxAspect = dims.Width / dims.Height;
            double actW, actH, offX, offY;
            if (imgAspect > boxAspect)
            {
                actW = dims.Width; actH = dims.Width / imgAspect;
                offX = 0; offY = (dims.Height - actH) / 2;
            }
            else
            {
                actH = dims.Height; actW = dims.Height * imgAspect;
                offX = (dims.Width - actW) / 2; offY = 0;
            }

            // Convert logical bounds to pixels in the rendered image, with padding so border sits outside the element
            var pad = 3.0;
            var pxLeft = (absBounds.Value.x / windowWidth) * actW + offX - pad;
            var pxTop = (absBounds.Value.y / windowHeight) * actH + offY - pad;
            var pxWidth = (absBounds.Value.w / windowWidth) * actW + pad * 2;
            var pxHeight = (absBounds.Value.h / windowHeight) * actH + pad * 2;

            overlayStyle = $"left: {pxLeft:F1}px; top: {pxTop:F1}px; width: {pxWidth:F1}px; height: {pxHeight:F1}px;";
        }
        catch { }
    }

    private async Task SelectElement(DevFlowElementInfo element)
    {
        selectedElement = element;
        selectedElementId = element.Id;
        editingProperty = null;
        locateElementId = null;
        overlayStyle = null;
        fetchedProperties.Clear();
        brushValueCache.Clear();

        var windowIndex = GetWindowIndex(element);
        if (windowIndex != selectedWindowIndex)
        {
            selectedWindowIndex = windowIndex;
        }

        StateHasChanged();

        // Fetch detailed element info and properties in parallel
        _ = Task.Run(async () =>
        {
            await InvokeAsync(async () =>
            {
                isLoadingProps = true;
                StateHasChanged();

                try
                {
                    // Get full element details
                    var detailed = await Client.GetElementAsync(element.Id);
                    if (detailed != null && selectedElementId == element.Id)
                    {
                        // Preserve bounds from hit test enrichment if the detailed response lacks them
                        if (detailed.WindowBounds == null && element.WindowBounds != null)
                            detailed.WindowBounds = element.WindowBounds;
                        if (detailed.Bounds == null && element.Bounds != null)
                            detailed.Bounds = element.Bounds;
                        selectedElement = detailed;
                    }

                    // Fetch common properties in parallel batches
                    var tasks = CommonProperties.Select(async prop =>
                    {
                        var val = await Client.GetPropertyAsync(element.Id, prop);
                        return new PropertyEntry(prop, val, GetMeta(prop));
                    });

                    var results = await Task.WhenAll(tasks);

                    if (selectedElementId == element.Id)
                    {
                        fetchedProperties = results
                            .Where(p => p.Value != null)
                            .OrderBy(p => Array.IndexOf(GroupOrder, p.Meta.Group))
                            .ThenBy(p => p.Meta.SortOrder)
                            .ThenBy(p => p.Name)
                            .ToList();
                    }
                }
                catch { }
                finally
                {
                    isLoadingProps = false;
                    StateHasChanged();
                }
            });
        });

        if (windowIndex != selectedWindowIndex || screenshotData == null)
        {
            await RefreshScreenshot(windowIndex);
        }
    }

    private int? GetWindowIndex(DevFlowElementInfo element)
    {
        for (int i = 0; i < treeItems.Count; i++)
        {
            if (ContainsElement(treeItems[i], element.Id))
                return i;
        }
        return null;
    }

    private bool ContainsElement(DevFlowElementInfo root, string id)
    {
        if (root.Id == id) return true;
        if (root.Children != null)
        {
            foreach (var child in root.Children)
            {
                if (ContainsElement(child, id))
                    return true;
            }
        }
        return false;
    }

