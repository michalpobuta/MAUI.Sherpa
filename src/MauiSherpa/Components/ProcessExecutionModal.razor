    }

    .btn-icon:hover { opacity: 1; }

    /* Dark mode overrides */
    .theme-dark .process-modal { background: var(--bg-secondary, #2d3748); }
    .theme-dark .modal-header { border-bottom-color: var(--border-color, #4a5568); }
    .theme-dark .modal-header h2 { color: var(--text-primary, #e2e8f0); }
    .theme-dark .close-btn { color: #a0aec0; }
    .theme-dark .close-btn:hover { color: #e2e8f0; }
    .theme-dark .modal-footer { border-top-color: var(--border-color, #4a5568); }
    .theme-dark .process-status-bar { background: var(--bg-tertiary, #374151); }
    .theme-dark .process-status-text { color: var(--text-primary, #e2e8f0); }
    .theme-dark .elapsed-time { color: #a0aec0; }
    .theme-dark .elevation-warning { background: rgba(237, 137, 54, 0.15); }
    .theme-dark .elevation-warning span { color: #fbd38d; }
    .theme-dark .exit-code-text { color: #a0aec0; }
    .theme-dark .result-status { background: var(--bg-tertiary, #374151); }
    .theme-dark .result-status.success { background: rgba(72, 187, 120, 0.15); }
    .theme-dark .result-status.error { background: rgba(245, 101, 101, 0.15); }
    .theme-dark .result-status.cancelled { background: rgba(237, 137, 54, 0.15); }
    .theme-dark .result-status.success .result-text { color: #9ae6b4; }
    .theme-dark .result-status.error .result-text { color: #feb2b2; }
    .theme-dark .result-status.cancelled .result-text { color: #fbd38d; }
    .theme-dark .detail-item { color: #a0aec0; }
    .theme-dark .btn-secondary { background: var(--btn-secondary-bg); color: var(--text-primary, #e2e8f0); }
    .theme-dark .btn-secondary:hover:not(:disabled) { background: #4a5568; }
</style>

@code {
    private enum ModalView { Confirmation, Running, Completed }

    private ModalView CurrentView { get; set; } = ModalView.Confirmation;
    private ProcessRequest? Request => ModalService.CurrentRequest;
    private bool IsVisible => ModalService.IsVisible;
    private ProcessResult? Result { get; set; }
    private string ElapsedTime { get; set; } = "00:00";
    private System.Timers.Timer? _elapsedTimer;
    private DateTime _startTime;
    private bool _terminalInitialized;
    private bool _needsCompletedTerminal;
    private CancellationTokenSource? _cts;
    private DotNetObjectReference<ProcessExecutionModal>? _dotNetRef;

    private bool CanCancel => ProcessService.CurrentState == ProcessState.Running;
    private bool CanKill => ProcessService.CurrentState == ProcessState.Running || 
                           ProcessService.CurrentState == ProcessState.Cancelled;

    protected override void OnInitialized()
    {
        ModalService.OnShowRequested += HandleShowRequested;
        ProcessService.OutputReceived += HandleOutputReceived;
        ProcessService.StateChanged += HandleStateChanged;
        _dotNetRef = DotNetObjectReference.Create(this);

        // Subscribe to native button clicks via bridge
        var bridge = BridgeHolder.Current;
        if (bridge != null)
        {
            bridge.ButtonClicked += OnBridgeButtonClicked;
        }

        // If already visible (timing: service fires before Blazor subscribes), catch up
        if (IsVisible && Request != null)
        {
            HandleShowRequested(Request);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsCompletedTerminal && Result != null)
        {
            _needsCompletedTerminal = false;
            await JS.InvokeVoidAsync("terminalInterop.initialize", "process-terminal", new { });
            _terminalInitialized = true;

            // Replay stdout
            if (!string.IsNullOrEmpty(Result.Output))
            {
                foreach (var line in Result.Output.Split('\n', StringSplitOptions.None))
                    await JS.InvokeVoidAsync("terminalInterop.write", "process-terminal", line);
            }

            // Replay stderr
            if (!string.IsNullOrEmpty(Result.Error))
            {
                foreach (var line in Result.Error.Split('\n', StringSplitOptions.None))
                    await JS.InvokeVoidAsync("terminalInterop.writeError", "process-terminal", line);
            }

            // Write final status line
            if (Result.Success)
                await JS.InvokeVoidAsync("terminalInterop.writeSuccess", "process-terminal", $"\n[OK] Process completed successfully (exit code {Result.ExitCode})");
            else if (Result.WasCancelled)
                await JS.InvokeVoidAsync("terminalInterop.writeWarning", "process-terminal", $"\n[CANCELLED] Process was cancelled");
            else if (Result.WasKilled)
                await JS.InvokeVoidAsync("terminalInterop.writeWarning", "process-terminal", $"\n[KILLED] Process was killed");
            else
                await JS.InvokeVoidAsync("terminalInterop.writeError", "process-terminal", $"\n[FAILED] Process failed (exit code {Result.ExitCode})");
        }
    }

    [JSInvokable]
    public void OnEscapePressed()
    {
        if (CurrentView == ModalView.Confirmation)
            HandleCancelBeforeExecution();
        else if (CurrentView == ModalView.Completed)
            HandleClose();
    }

    private void HandleShowRequested(ProcessRequest request)
    {
        CurrentView = ModalService.RequiresConfirmation ? ModalView.Confirmation : ModalView.Running;
        Result = null;
        _terminalInitialized = false;
        UpdateBridgeButtons();
        InvokeAsync(StateHasChanged);

        if (!ModalService.RequiresConfirmation)
        {
            _ = ExecuteProcessAsync();
        }
    }

    private async void HandleOutputReceived(object? sender, ProcessOutputEventArgs e)
    {
        await InvokeAsync(async () =>
        {
            if (_terminalInitialized)
            {
                if (e.IsError)
                    await JS.InvokeVoidAsync("terminalInterop.writeError", "process-terminal", e.Data);
                else
                    await JS.InvokeVoidAsync("terminalInterop.write", "process-terminal", e.Data);
            }
        });
    }

    private async void HandleStateChanged(object? sender, ProcessStateChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleExecute()
    {
        CurrentView = ModalView.Running;
        UpdateBridgeButtons();
        StateHasChanged();

        // Wait a tick for the terminal container to render
        await Task.Delay(50);

        await ExecuteProcessAsync();
    }

    private async Task ExecuteProcessAsync()
    {
        if (Request == null) return;

        // Initialize terminal
        await JS.InvokeVoidAsync("terminalInterop.initialize", "process-terminal", new { });
        _terminalInitialized = true;

        // Start elapsed timer
        _startTime = DateTime.Now;
        _elapsedTimer = new System.Timers.Timer(1000);
        _elapsedTimer.Elapsed += (_, _) =>
        {
            var elapsed = DateTime.Now - _startTime;
            ElapsedTime = elapsed.ToString(@"mm\:ss");
            InvokeAsync(StateHasChanged);
        };
        _elapsedTimer.Start();

        // Execute
        _cts = new CancellationTokenSource();
        try
        {
            Result = await ProcessService.ExecuteAsync(Request, _cts.Token);
        }
        catch (Exception ex)
        {
            Result = new ProcessResult(-1, "", ex.Message, DateTime.Now - _startTime, ProcessState.Failed);
        }
        finally
        {
            _elapsedTimer?.Stop();
            _elapsedTimer?.Dispose();
            _elapsedTimer = null;
        }

        // Transition to completed view — terminal will be re-initialized in OnAfterRenderAsync
        _needsCompletedTerminal = true;
        CurrentView = ModalView.Completed;
        ModalService.CompleteWithResult(Result);
        UpdateBridgeButtons();
        StateHasChanged();
    }

    private void HandleCancelBeforeExecution()
    {
        ModalService.CancelBeforeExecution();
    }

    private void HandleCancel()
    {
        ProcessService.Cancel();
    }

    private void HandleKill()
    {
        ProcessService.Kill();
    }

    private void HandleClose()
    {
        if (_terminalInitialized)
        {
            _ = JS.InvokeVoidAsync("terminalInterop.dispose", "process-terminal");
        }
        ModalService.Close();
        BridgeHolder.Current?.RequestClose();
    }

    private void UpdateBridgeButtons()
    {
        var bridge = BridgeHolder.Current;
        if (bridge == null) return;

        switch (CurrentView)
        {
            case ModalView.Confirmation:
                bridge.SetTitle(Request?.Title ?? "Confirm Execution");
                bridge.SetButtons(
                    new ProgressButton("cancel", "Cancel", ProgressButtonStyle.Secondary),
                    new ProgressButton("execute", Request?.RequiresElevation == true ? "🔐 Execute" : "Execute", ProgressButtonStyle.Primary));
                break;
            case ModalView.Running:
                bridge.SetTitle(Request?.Title ?? "Running Process");
                bridge.SetButtons(); // No footer buttons during running — controls are inline
                break;
            case ModalView.Completed:
                bridge.SetTitle("Process Complete");
                var buttons = new List<ProgressButton>();
                if (Result != null && !Result.Success && !Result.WasCancelled && !Result.WasKilled)
                    buttons.Add(new ProgressButton("copilot", "Try with Copilot", ProgressButtonStyle.Copilot, "fas fa-robot"));
                buttons.Add(new ProgressButton("close", "Close", ProgressButtonStyle.Primary));
                bridge.SetButtons(buttons.ToArray());
                break;
        }
    }

    private async Task OnBridgeButtonClicked(string buttonId)
    {
        await InvokeAsync(async () =>
        {
            switch (buttonId)
            {
                case "cancel":
                    HandleCancelBeforeExecution();
                    break;
                case "execute":
                    await HandleExecute();
                    break;
                case "copilot":
                    await HandleTryWithCopilot();
                    break;
                case "close":
                    HandleClose();
                    break;
            }
        });
    }

    private async Task HandleTryWithCopilot()
    {
        var output = "";
        if (_terminalInitialized)
        {
            try
            {
                output = await JS.InvokeAsync<string>("terminalInterop.getContent", "process-terminal");
            }
            catch { }
        }
        
        // Build context
        var context = CopilotContextService.BuildProcessFailureContext(
            Request?.CommandLine ?? "Unknown command",
            Result?.ExitCode ?? -1,
            output
        );
        
        // Close the modal FIRST, then open Copilot after the pop completes
        HandleClose();
        
        // Defer Copilot open to avoid racing PushModal vs PopModal
        _ = Task.Run(async () =>
        {
            await Task.Delay(300);
            Application.Current?.Dispatcher.Dispatch(() => CopilotContext.OpenWithContext(context));
        });
    }

    private async Task CopyOutput()
    {
        if (_terminalInitialized)
        {
            var content = await JS.InvokeAsync<string>("terminalInterop.getContent", "process-terminal");
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
        }
    }

    private string GetTitle()
    {
        return Request?.Title ?? CurrentView switch
        {
            ModalView.Confirmation => "Confirm Execution",
            ModalView.Running => "Running Process",
            ModalView.Completed => "Process Complete",
            _ => "Process Execution"
        };
    }

    private string GetResultClass()
    {
        if (Result == null) return "";
        if (Result.Success) return "success";
        if (Result.WasCancelled || Result.WasKilled) return "cancelled";
        return "error";
    }

    private string GetResultIcon()
    {
        if (Result == null) return "";
        if (Result.Success) return "fa-check-circle";
        if (Result.WasCancelled || Result.WasKilled) return "fa-ban";
        return "fa-times-circle";
    }

    private string GetResultText()
    {
        if (Result == null) return "";
        if (Result.Success) return "Process completed successfully";
        if (Result.WasCancelled) return "Process was cancelled";
        if (Result.WasKilled) return "Process was killed";
        return "Process failed";
    }

    public void Dispose()
    {
        ModalService.OnShowRequested -= HandleShowRequested;
        ProcessService.OutputReceived -= HandleOutputReceived;
        ProcessService.StateChanged -= HandleStateChanged;
        _elapsedTimer?.Dispose();
        _cts?.Dispose();
        var bridge = BridgeHolder.Current;
        if (bridge != null)
            bridge.ButtonClicked -= OnBridgeButtonClicked;
        _dotNetRef?.Dispose();
    }
}
