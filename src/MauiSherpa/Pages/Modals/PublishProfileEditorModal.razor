        background: var(--input-bg, #fff);
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .search-box:focus-within {
        border-color: var(--accent-color, #3b82f6);
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
    }

