@page "/modal/publish-review"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.Requests.Publisher
@using MauiSherpa.Pages.Forms
@using Shiny.Mediator
@inject HybridFormBridgeHolder BridgeHolder
@inject ISecretsPublisherService PublisherService
@inject ISecretsPublisherFactory PublisherFactory
@inject IPublishProfileService ProfileService
@inject ILoggingService Logger
@inject IMediator Mediator
@implements IDisposable

<div class="publish-review">
    @if (isResolving)
    {
        <div class="resolving-state">
            <i class="fa-solid fa-spinner fa-spin" style="font-size: 24px; color: var(--accent-color, #3b82f6);"></i>
            <h3>Resolving Secrets</h3>
            <p class="step-description">@resolvingStatus</p>
        </div>
    }
    else if (resolveError is not null)
    {
        <div class="resolving-state">
            <i class="fa-solid fa-circle-xmark" style="font-size: 24px; color: #ef4444;"></i>
            <h3>Failed to Resolve</h3>
            <p class="step-description">@resolveError</p>
        </div>
    }
    else if (step == 1)
    {
        <h3>Review Secrets</h3>
        <p class="step-description">Select which secrets to publish. Uncheck any you want to exclude.</p>

        @if (resolveWarnings.Count > 0)
        {
            <div class="resolve-warnings">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <div>
                    <strong>Some items could not be resolved:</strong>
                    <ul>
                        @foreach (var w in resolveWarnings)
                        {
                            <li>@w</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <div class="select-controls">
            <span class="select-count">@checkedSecrets.Count(kv => kv.Value) of @checkedSecrets.Count selected</span>
            <button class="btn-text-action" @onclick="ToggleAllSecrets">
                @(checkedSecrets.All(kv => kv.Value) ? "Uncheck All" : "Check All")
            </button>
        </div>

        <div class="secrets-checklist">
            @foreach (var key in secretKeys)
            {
                <label class="check-item">
                    <input type="checkbox" checked="@checkedSecrets[key]"
                           @onchange="@(e => { checkedSecrets[key] = (bool)(e.Value ?? false); UpdateWizardState(); })" />
                    <span class="check-label mono">@key</span>
                </label>
            }
        </div>
    }
    else if (step == 2)
    {
        <h3>Review Destinations</h3>
        <p class="step-description">Select which repositories to publish to.</p>

        @if (destinations.Any())
        {
            <div class="destinations-checklist">
                @foreach (var dest in destinations)
                {
                    <label class="check-item destination-item">
                        <input type="checkbox" checked="@dest.Checked"
                               @onchange="@(e => { dest.Checked = (bool)(e.Value ?? false); UpdateWizardState(); })" />
                        <div class="dest-info">
                            <i class="@GetProviderIcon(dest.ProviderId)"></i>
                            <div class="dest-details">
                                <span class="dest-repo">@dest.RepositoryFullName</span>
                                <span class="dest-provider">@dest.PublisherName</span>
                            </div>
                        </div>
                    </label>
                }
            </div>
        }
        else
        {
            <div class="empty-hint">No destinations configured in this profile.</div>
        }

        @if (!showAddDestination)
        {
            <button class="btn-text-action" style="margin-top: 8px;" @onclick="@(() => showAddDestination = true)">
                <i class="fa-solid fa-plus"></i> Add Destination
            </button>
        }
        else
        {
            <div class="add-dest-section">
                @if (addDestStep == 0)
                {
                    <div class="add-dest-header">
                        <span class="add-dest-title">Choose Provider</span>
                        <button class="btn-icon-action" @onclick="@(() => showAddDestination = false)">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="selection-list compact">
                        @foreach (var pub in allPublishers)
                        {
                            <label class="selection-item" @onclick="@(() => SelectAddPublisher(pub))">
                                <div class="item-content">
                                    <div class="item-name"><i class="@GetProviderIcon(pub.ProviderId)" style="margin-right: 6px;"></i>@pub.Name</div>
                                    <div class="item-detail">@pub.ProviderId</div>
                                </div>
                                <i class="fa-solid fa-chevron-right" style="color: var(--text-muted); font-size: 11px;"></i>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <div class="add-dest-header">
                        <button class="btn-text-action" @onclick="@(() => { addDestStep = 0; addDestPublisher = null; })">
                            <i class="fa-solid fa-arrow-left"></i> Back
                        </button>
                        <button class="btn-icon-action" @onclick="@(() => { showAddDestination = false; addDestStep = 0; addDestPublisher = null; })">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" @bind="addDestRepoSearch" @bind:event="oninput"
                               placeholder="Search repositories..." />
                        @if (!string.IsNullOrEmpty(addDestRepoSearch))
                        {
                            <button class="clear-search" @onclick="@(() => addDestRepoSearch = "")">×</button>
                        }
                    </div>
                    @if (addDestLoadingRepos)
                    {
                        <div class="loading-hint"><i class="fa-solid fa-spinner fa-spin"></i> Loading repositories...</div>
                    }
                    else if (addDestFilteredRepos.Any())
                    {
                        <div class="selection-list compact">
                            @foreach (var repo in addDestFilteredRepos.Take(20))
                            {
                                <label class="selection-item" @onclick="@(() => AddNewDestination(repo))">
                                    <div class="item-content">
                                        <div class="item-name">@repo.FullName</div>
                                        <div class="item-detail">@(string.IsNullOrEmpty(repo.Description) ? "\u00A0" : repo.Description)</div>
                                    </div>
                                </label>
                            }
                        </div>
                    }
                    else if (!addDestLoadingRepos)
                    {
                        <div class="empty-hint">No repositories found</div>
                    }
                }
            </div>
        }
    }
    else if (step == 3)
    {
        <h3>Publishing</h3>
        <p class="step-description">
            @if (publishComplete)
            {
                @:All operations complete.
            }
            else
            {
                @:Publishing secrets to selected destinations...
            }
        </p>

        <div class="publish-status-list">
            @foreach (var dest in destinations.Where(d => d.Checked))
            {
                <div class="publish-status-row">
                    <div class="status-icon">
                        @if (dest.Status == PublishStatus.InProgress)
                        {
                            <i class="fa-solid fa-spinner fa-spin" style="color: var(--accent-color, #3b82f6);"></i>
                        }
                        else if (dest.Status == PublishStatus.Success)
                        {
                            <i class="fa-solid fa-circle-check" style="color: #22c55e;"></i>
                        }
                        else if (dest.Status == PublishStatus.Error)
                        {
                            <i class="fa-solid fa-circle-xmark" style="color: #ef4444;"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-circle" style="color: var(--text-muted); font-size: 10px;"></i>
                        }
                    </div>
                    <div class="status-info">
                        <div class="status-dest">
                            <i class="@GetProviderIcon(dest.ProviderId)" style="margin-right: 4px;"></i>
                            @dest.RepositoryFullName
                        </div>
                        <div class="status-message">@dest.StatusMessage</div>
                    </div>
                </div>
            }
        </div>

        @if (publishComplete)
        {
            var successCount = destinations.Count(d => d.Checked && d.Status == PublishStatus.Success);
            var errorCount = destinations.Count(d => d.Checked && d.Status == PublishStatus.Error);
            <div class="publish-summary-bar">
                @if (errorCount == 0)
                {
                    <i class="fa-solid fa-circle-check" style="color: #22c55e;"></i>
                    <span>Published @selectedSecretCount secret(s) to @successCount destination(s)</span>
                }
                else
                {
                    <i class="fa-solid fa-triangle-exclamation" style="color: #f59e0b;"></i>
                    <span>@successCount succeeded, @errorCount failed</span>
                }
            </div>
        }
    }
</div>

