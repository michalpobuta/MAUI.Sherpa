                ctx.LogInfo($"Simulator: {sim.Name}");
                ctx.LogInfo($"UDID: {sim.Udid}");
                ctx.SetStatus("Erasing content and settings...");

                var success = await SimulatorService.EraseSimulatorAsync(sim.Udid,
