    }

    .secret-picker-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-color, #e2e8f0);
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .secret-picker-header i {
        margin-right: 6px;
    }

    .secret-picker-body {
