@page "/settings"
@page "/modal/settings"
@using MauiSherpa.Core.ViewModels
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.Services
@using MauiSherpa.Core.Requests.Android
@using Shiny.Mediator
@inject SettingsViewModel ViewModel
@inject IMediator Mediator
@inject IAppleIdentityService AppleIdentityService
@inject IAppleIdentityStateService IdentityState
@inject IGoogleIdentityService GoogleIdentityService
@inject IAndroidSdkService SdkService
@inject IAndroidSdkSettingsService SdkSettings
@inject IOpenJdkSettingsService JdkSettings
@inject IAlertService AlertService
@inject IDialogService DialogService
@inject IFileSystemService FileSystem
@inject IThemeService ThemeService
@inject ICloudSecretsService CloudSecretsService
@inject ICloudSecretsProviderFactory CloudSecretsProviderFactory
@inject ISecretsPublisherService SecretsPublisherService
@inject IPushProjectService PushProjectService
@inject IEncryptedSettingsService EncryptedSettings
@inject IUpdateService UpdateService
@implements IDisposable
@inject ILauncher AppLauncher
@inject IToolbarService ToolbarService
@inject IPlatformService PlatformInfo
@inject MauiSherpa.Pages.Forms.ModalParameterService ModalParams

@if (!PlatformInfo.HasNativeToolbar)
{
<h1><i class="fas fa-cog"></i> @ViewModel.Title</h1>
}

<div class="settings-section">
    <h2>General</h2>
    <div class="settings-container">
        <div class="setting-group">
            <div class="setting-item">
                <label class="setting-label">Theme</label>
                <select value="@ViewModel.Theme" @onchange="OnThemeChanged">
                    <option value="System">System</option>
                    <option value="Light">Light</option>
                    <option value="Dark">Dark</option>
                </select>
            </div>
            <div class="setting-item">
                <label class="setting-label">Demo Mode</label>
                <div class="setting-toggle-row">
                    <label class="toggle-switch">
                        <input type="checkbox" checked="@demoMode" @onchange="OnDemoModeChanged" />
                        <span class="toggle-slider"></span>
                    </label>
                    <span class="setting-description">Blur sensitive values (IDs, UDIDs, serials) for presentations</span>
                </div>
            </div>
            <div class="setting-item">
                <label class="setting-label">Font Size</label>
                <div class="font-scale-control">
                    <button class="btn-scale" @onclick="DecreaseFontScale" disabled="@(ViewModel.FontScale <= 0.8)" title="Decrease font size">
                        <i class="fas fa-minus"></i>
                    </button>
                    <input type="range" min="0.8" max="1.5" step="0.05"
                           value="@ViewModel.FontScale"
                           @oninput="OnFontScaleInput"
                           class="font-scale-slider" />
                    <button class="btn-scale" @onclick="IncreaseFontScale" disabled="@(ViewModel.FontScale >= 1.5)" title="Increase font size">
                        <i class="fas fa-plus"></i>
                    </button>
                    <span class="font-scale-label">@($"{ViewModel.FontScale * 100:F0}%")</span>
                </div>
            </div>
        </div>

        <div class="actions">
            @if (!PlatformInfo.HasNativeToolbar)
            {
            <button class="btn btn-primary" @onclick="SaveSettings">
                <i class="fas fa-save"></i> Save Settings
            </button>
            <button class="btn btn-secondary" @onclick="ResetSettings">
                <i class="fas fa-undo"></i> Reset to Defaults
            </button>
            }
        </div>
        
        <div class="setting-group" style="margin-top: 1.5rem;">
            <div class="setting-item">
                <label class="setting-label">Version</label>
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <span class="mono text-selectable">@appVersion</span>
                    @if (updateResult?.UpdateAvailable == true && updateResult.LatestRelease != null)
                    {
                        <button class="btn btn-sm btn-update-available" @onclick="ShowUpdateDialog">
                            <i class="fas fa-arrow-circle-up"></i>
                            @(updateResult.LatestRelease.TagName) available
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="settings-section">
    <h2><i class="fab fa-android"></i> Android SDK</h2>
    <p class="section-description">
        Configure the Android SDK location used for managing packages, emulators, and devices.
    </p>
    
    <div class="settings-container">
        <div class="sdk-path-setting">
            <div class="sdk-path-info">
                <div class="detail-item">
                    <span class="detail-label">SDK PATH</span>
                    <div class="path-input-group">
                        @if (isLoadingSdk)
                        {
                            <span class="detecting"><i class="fas fa-spinner fa-spin"></i> Detecting...</span>
                        }
                        else
                        {
                            <input type="text" 
                                   class="path-input mono" 
                                   @bind="editableSdkPath" 
                                   @bind:event="oninput"
                                   placeholder="Enter Android SDK path or use Browse button"
                                   disabled="@isLoadingSdk" />
                            <div class="path-actions">
                                <button class="btn-icon-action" @onclick="@(() => CopyToClipboard(editableSdkPath))" title="Copy to clipboard" disabled="@(string.IsNullOrEmpty(editableSdkPath))">
                                    <i class="fas fa-copy"></i>
                                </button>
                                <button class="btn-icon-action" @onclick="@(() => FileSystem.RevealInFileManager(editableSdkPath))" title="Reveal in Finder" disabled="@(string.IsNullOrEmpty(editableSdkPath))">
                                    <i class="fas fa-external-link-alt"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(SdkSettings.CustomSdkPath))
                {
                    <div class="custom-path-badge">
                        <i class="fas fa-user-edit"></i> Custom path
                    </div>
                }
            </div>
            <div class="sdk-path-actions">
                <button class="btn btn-secondary btn-sm" @onclick="ApplySdkPath" disabled="@(isLoadingSdk || !HasSdkPathChanged)">
                    <i class="fas fa-check"></i> Apply
                </button>
                <button class="btn btn-secondary btn-sm" @onclick="ChangeSdkPath" disabled="@isLoadingSdk">
                    <i class="fas fa-folder-open"></i> Browse
                </button>
                @if (!string.IsNullOrEmpty(SdkSettings.CustomSdkPath))
                {
                    <button class="btn btn-secondary btn-sm" @onclick="ResetSdkPath" disabled="@isLoadingSdk">
                        <i class="fas fa-undo"></i> Reset to Default
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<div class="settings-section">
    <h2><i class="fab fa-java"></i> OpenJDK</h2>
    <p class="section-description">
        Configure the OpenJDK location used for keystore management and PEPK exports.
    </p>

    <div class="settings-container">
        <div class="sdk-path-setting">
            <div class="sdk-path-info">
                <div class="detail-item">
                    <span class="detail-label">JDK PATH</span>
                    <div class="path-input-group">
                        @if (isLoadingJdk)
                        {
                            <span class="detecting"><i class="fas fa-spinner fa-spin"></i> Detecting...</span>
                        }
                        else
                        {
                            <input type="text" 
                                   class="path-input mono" 
                                   @bind="editableJdkPath" 
                                   @bind:event="oninput"
                                   placeholder="Enter OpenJDK path or use Browse button"
                                   disabled="@isLoadingJdk" />
                            <div class="path-actions">
                                <button class="btn-icon-action" @onclick="@(() => CopyToClipboard(editableJdkPath))" title="Copy to clipboard" disabled="@(string.IsNullOrEmpty(editableJdkPath))">
                                    <i class="fas fa-copy"></i>
                                </button>
                                <button class="btn-icon-action" @onclick="@(() => FileSystem.RevealInFileManager(editableJdkPath))" title="Reveal in Finder" disabled="@(string.IsNullOrEmpty(editableJdkPath))">
                                    <i class="fas fa-external-link-alt"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(JdkSettings.CustomJdkPath))
                {
                    <div class="custom-path-badge">
                        <i class="fas fa-user-edit"></i> Custom path
                    </div>
                }
            </div>
            <div class="sdk-path-actions">
                <button class="btn btn-secondary btn-sm" @onclick="ApplyJdkPath" disabled="@(isLoadingJdk || !HasJdkPathChanged)">
                    <i class="fas fa-check"></i> Apply
                </button>
                <button class="btn btn-secondary btn-sm" @onclick="ChangeJdkPath" disabled="@isLoadingJdk">
                    <i class="fas fa-folder-open"></i> Browse
                </button>
                @if (!string.IsNullOrEmpty(JdkSettings.CustomJdkPath))
                {
                    <button class="btn btn-secondary btn-sm" @onclick="ResetJdkPath" disabled="@isLoadingJdk">
                        <i class="fas fa-undo"></i> Reset to Default
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<div class="settings-section" id="settings-apple-identities">
    <h2><i class="fab fa-apple"></i> Apple Identities</h2>
    <p class="section-description">
        Configure App Store Connect API credentials for managing Apple Developer resources.
        <a href="https://appstoreconnect.apple.com/access/integrations/api" target="_blank">Get API keys</a>
    </p>
    
    @if (appleIdentities.Count == 0)
    {
        <div class="settings-container">
            <div class="empty-identities">
                <p>No Apple identities configured</p>
            </div>
        </div>
    }
    else
    {
        <div class="connected-list">
            @foreach (var identity in appleIdentities)
            {
                <div class="connected-list-item">
                    <div class="identity-header">
                        <div class="identity-info">
                            <i class="fas fa-id-badge identity-icon"></i>
                            <span class="identity-name">@identity.Name</span>
                        </div>
                        <div class="identity-actions">
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => TestIdentity(identity))" title="Test Connection">
                                <i class="fas fa-plug"></i> Test
                            </button>
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => EditIdentity(identity))" title="Edit">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteIdentity(identity))" title="Delete">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                    <div class="identity-details">
                        <div class="detail-item">
                            <span class="detail-label">KEY ID</span>
                            <span class="detail-value mono copyable">
                                <span class="@(demoMode ? "demo-blur" : "")">@identity.KeyId</span>
                                <button class="btn-copy" @onclick="@(() => CopyToClipboard(identity.KeyId))" title="Copy to clipboard">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">ISSUER ID</span>
                            <span class="detail-value mono copyable">
                                <span class="@(demoMode ? "demo-blur" : "")">@identity.IssuerId</span>
                                <button class="btn-copy" @onclick="@(() => CopyToClipboard(identity.IssuerId))" title="Copy to clipboard">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    
    <div class="section-add-action">
        <button class="btn btn-success" @onclick="ShowAddIdentityDialog">
            <i class="fas fa-plus"></i> Add Apple Identity
        </button>
    </div>
</div>

<div class="settings-section" id="settings-google-identities">
    <h2><i class="fab fa-google"></i> Google Identities</h2>
    <p class="section-description">
        Configure Google Cloud / Firebase service account credentials for push notifications and project management.
        <a href="https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk" target="_blank">Get service account JSON</a>
    </p>
    
    @if (googleIdentities.Count == 0)
    {
        <div class="settings-container">
            <div class="empty-identities">
                <p>No Google identities configured</p>
            </div>
        </div>
    }
    else
    {
        <div class="connected-list">
            @foreach (var identity in googleIdentities)
            {
                <div class="connected-list-item">
                    <div class="identity-header">
                        <div class="identity-info">
                            <i class="fab fa-google identity-icon"></i>
                            <span class="identity-name">@identity.Name</span>
                        </div>
                        <div class="identity-actions">
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => TestGoogleIdentity(identity))" title="Test Connection">
                                <i class="fas fa-plug"></i> Test
                            </button>
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => EditGoogleIdentity(identity))" title="Edit">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteGoogleIdentity(identity))" title="Delete">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                    <div class="identity-details">
                        <div class="detail-item">
                            <span class="detail-label">PROJECT</span>
                            <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@identity.ProjectId</span></span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">SERVICE ACCOUNT</span>
                            <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@identity.ClientEmail</span></span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    
    <div class="section-add-action">
        <button class="btn btn-success" @onclick="ShowAddGoogleIdentityDialog">
            <i class="fas fa-plus"></i> Add Google Identity
        </button>
    </div>
</div>

<div class="settings-section">
    <h2><i class="fas fa-cloud"></i> Cloud Secrets Storage</h2>
    <p class="section-description">
        Store certificate private keys securely in the cloud to sync across machines.
        This enables sharing signing certificates between development machines and CI/CD pipelines.
    </p>
    
    @if (cloudProviders.Count == 0)
    {
        <div class="settings-container">
            <div class="empty-providers">
                <p>No cloud providers configured</p>
            </div>
        </div>
    }
    else
    {
        <div class="connected-list">
            @foreach (var provider in cloudProviders)
            {
                var isActive = CloudSecretsService.ActiveProvider?.Id == provider.Id;
                var providerUrl = GetProviderUrl(provider);
                <div class="connected-list-item @(isActive ? "active" : "")">
                    <div class="provider-header">
                        <div class="provider-info">
                            <i class="@GetProviderIcon(provider.ProviderType) provider-icon"></i>
                            <span class="provider-name">@provider.Name</span>
                            @if (!string.IsNullOrEmpty(providerUrl))
                            {
                                <a href="@providerUrl" target="_blank" class="provider-link" title="Open in browser">
                                    <i class="fas fa-external-link-alt"></i>
                                </a>
                            }
                            @if (isActive)
                            {
                                <span class="active-badge">Active</span>
                            }
                        </div>
                        <div class="provider-actions">
                            @if (!isActive)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="@(() => SetActiveProvider(provider))" title="Set as Active">
                                    <i class="fas fa-check"></i> Activate
                                </button>
                            }
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => TestProvider(provider))" title="Test Connection">
                                <i class="fas fa-plug"></i> Test
                            </button>
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => EditProvider(provider))" title="Edit">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteProvider(provider))" title="Delete">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                    <div class="provider-details">
                        <div class="detail-item">
                            <span class="detail-label">TYPE</span>
                            <span class="detail-value">@CloudSecretsProviderFactory.GetProviderDisplayName(provider.ProviderType)</span>
                        </div>
                        @if (provider.ProviderType == CloudSecretsProviderType.Infisical)
                        {
                            <div class="detail-item">
                                <span class="detail-label">SITE</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("SiteUrl", "https://app.infisical.com")</span></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">PROJECT</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("ProjectId", "")</span></span>
                            </div>
                        }
                        @if (provider.ProviderType == CloudSecretsProviderType.AzureKeyVault)
                        {
                            <div class="detail-item">
                                <span class="detail-label">VAULT</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("VaultUrl", "")</span></span>
                            </div>
                        }
                        @if (provider.ProviderType == CloudSecretsProviderType.AwsSecretsManager)
                        {
                            <div class="detail-item">
                                <span class="detail-label">REGION</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("Region", "us-east-1")</span></span>
                            </div>
                        }
                        @if (provider.ProviderType == CloudSecretsProviderType.GoogleSecretManager)
                        {
                            <div class="detail-item">
                                <span class="detail-label">PROJECT</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("ProjectId", "")</span></span>
                            </div>
                        }
                        @if (provider.ProviderType == CloudSecretsProviderType.OnePassword)
                        {
                            <div class="detail-item">
                                <span class="detail-label">VAULT</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("Vault", "")</span></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">ITEM</span>
                                <span class="detail-value mono"><span class="@(demoMode ? "demo-blur" : "")">@provider.Settings.GetValueOrDefault("ItemTitle", "MAUI.Sherpa")</span></span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    
    <div class="section-add-action">
        <button class="btn btn-success" @onclick="ShowAddProviderDialog">
            <i class="fas fa-plus"></i> Add Cloud Provider
        </button>
    </div>
</div>

<!-- CI/CD Secret Publishers Section -->
<div class="settings-section">
    <h2><i class="fas fa-rocket"></i> CI/CD Secret Publishers</h2>
    <p class="section-description">
        Publish signing secrets directly to your CI/CD platforms for automated builds.
        Secrets will be encrypted and stored as repository secrets.
    </p>
    
    @if (secretsPublishers.Count == 0)
    {
        <div class="settings-container">
            <div class="empty-providers">
                <p>No CI/CD publishers configured</p>
            </div>
        </div>
    }
    else
    {
        <div class="connected-list">
            @foreach (var publisher in secretsPublishers)
            {
                <div class="connected-list-item">
                    <div class="provider-header">
                        <div class="provider-info">
                            <i class="@GetPublisherIcon(publisher.ProviderId) provider-icon"></i>
                            <span class="provider-name">@publisher.Name</span>
                        </div>
                        <div class="provider-actions">
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => TestPublisher(publisher))" title="Test Connection">
                                <i class="fas fa-plug"></i> Test
                            </button>
                            <button class="btn btn-sm btn-secondary" @onclick="@(() => EditPublisher(publisher))" title="Edit">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="@(() => DeletePublisher(publisher))" title="Delete">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                    <div class="provider-details">
                        <div class="detail-item">
                            <span class="detail-label">TYPE</span>
                            <span class="detail-value">@GetPublisherDisplayName(publisher.ProviderId)</span>
                        </div>
                        @if (publisher.ProviderId == "github")
                        {
                            var owner = publisher.Settings.GetValueOrDefault("Owner", "");
                            @if (!string.IsNullOrEmpty(owner))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">OWNER</span>
                                    <span class="detail-value mono">@owner</span>
                                </div>
                            }
                        }
                        @if (publisher.ProviderId == "gitea" || publisher.ProviderId == "gitlab")
                        {
                            <div class="detail-item">
                                <span class="detail-label">SERVER</span>
                                <span class="detail-value mono">@publisher.Settings.GetValueOrDefault("ServerUrl", "")</span>
                            </div>
                        }
                        @if (publisher.ProviderId == "azuredevops")
                        {
                            <div class="detail-item">
                                <span class="detail-label">ORG</span>
                                <span class="detail-value mono">@publisher.Settings.GetValueOrDefault("OrganizationUrl", "")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    
    <div class="section-add-action">
        <button class="btn btn-success" @onclick="ShowAddPublisherDialog">
            <i class="fas fa-plus"></i> Add CI/CD Publisher
        </button>
    </div>
</div>

<!-- Backup & Restore Section -->
<div class="settings-section">
    <h2><i class="fas fa-shield-alt"></i> Backup & Restore</h2>
    <p class="section-description">
        Export your settings to a password-protected file for backup or transfer to another machine.
        All sensitive data (API keys, tokens) are encrypted using AES-256-GCM.
    </p>
    
    <div class="backup-actions">
        <div class="backup-action-card">
                <div class="backup-icon export">
                    <i class="fas fa-download"></i>
                </div>
                <div class="backup-info">
                    <h3>Export Settings</h3>
                    <p>Create a password-protected backup and choose exactly which settings, identities, providers, and CI/CD publishers to include.</p>
                </div>
                <button class="btn btn-primary" @onclick="ShowExportDialog" disabled="@isExporting">
                    @if (isExporting)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Exporting...</span>
                    }
                    else
                    {
                        <i class="fas fa-file-export"></i>
                        <span>Export</span>
                    }
                </button>
            </div>
            
            <div class="backup-action-card">
                <div class="backup-icon import">
                    <i class="fas fa-upload"></i>
                </div>
                <div class="backup-info">
                    <h3>Import Settings</h3>
                    <p>Restore settings from a backup file. This will merge with or replace your existing settings.</p>
                </div>
                <button class="btn btn-secondary" @onclick="ShowImportDialog" disabled="@isImporting">
                    @if (isImporting)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Importing...</span>
                    }
                    else
                    {
                        <i class="fas fa-file-import"></i>
                        <span>Import</span>
                    }
                </button>
            </div>
        </div>
</div>

<UpdateAvailableModal
    @ref="updateModal"
    UpdateResult="@updateResult"
    IsVisible="@showUpdateDialog"
    OnAccept="@HandleSettingsUpdateAccept"
    OnDecline="@HandleSettingsUpdateDecline"
    OnAutoUpdate="@HandleSettingsAutoUpdate" />

<style>
    h1 { margin-bottom: 1.25rem; font-size: 1.75rem; color: var(--text-primary); font-weight: 600; }
    h2 { margin: 0 0 0.25rem 0; font-size: 1.125rem; color: var(--text-primary); font-weight: 600; display: flex; align-items: center; gap: 0.625rem; }
    h2 i { color: var(--text-secondary); }

    /* Extra padding when rendered inside hybrid modal dialog */
    .modal-layout .settings-section { padding-left: 24px; padding-right: 24px; }
    .modal-layout .settings-section:first-child { padding-top: 16px; }

    .settings-section { margin-bottom: 1.25rem; }
    .section-description { color: var(--text-muted); margin-bottom: 0.5rem; font-size: 0.875rem; }
    .section-description a { color: var(--accent-primary); }

    .btn-update-available {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.625rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(52, 211, 153, 0.15);
        color: var(--accent-success, #34d399);
