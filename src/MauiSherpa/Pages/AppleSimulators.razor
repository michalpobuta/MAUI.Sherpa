    {
        openDropdownId = null;
    }

    // Physical devices
    private async Task RefreshPhysicalDevices()
    {
        isLoadingDevices = true;
        try
        {
            var devices = await PhysicalDeviceService.GetDevicesAsync();
            physicalDevices = devices.ToList();
        }
        catch { }
        finally
        {
            isLoadingDevices = false;
            StateHasChanged();
        }
    }

    private async Task InstallAppOnDevice(PhysicalDevice device)
    {
        var appPath = await DialogService.PickOpenFileAsync("Select App Bundle", new[] { "app", "ipa" });
        if (string.IsNullOrEmpty(appPath)) return;

        await OperationModal.RunAsync(
            $"Installing app on {device.Name}",
            "Installing application...",
            async (ctx) =>
            {
                ctx.SetStatus("Installing...");
                var success = await PhysicalDeviceService.InstallAppAsync(device.Identifier, appPath,
                    new Progress<string>(msg => { ctx.LogInfo(msg); ctx.SetStatus(msg); }));
                if (success) ctx.LogSuccess("App installed successfully");
                return success;
            }
        );
    }

    public void Dispose()
    {
        ToolbarService.ToolbarItemClicked -= OnToolbarItemClicked;
        ToolbarService.SearchTextChanged -= OnSearchTextChanged;
        ToolbarService.FilterChanged -= OnFilterChanged;
    }

    private void OnSearchTextChanged(string text)
    {
        InvokeAsync(() => { searchQuery = text; StateHasChanged(); });
    }

    private void OnFilterChanged(string filterId, int selectedIndex)
    {
        InvokeAsync(() =>
        {
            switch (filterId)
            {
                case "state":
                    filterState = selectedIndex switch { 1 => "Booted", 2 => "Shutdown", _ => "" };
                    break;
                case "family":
                    var families = new[] { "" }.Concat(productFamilies).ToArray();
                    filterFamily = selectedIndex < families.Length ? families[selectedIndex] : "";
                    break;
                case "runtime":
                    var runtimes = new[] { "" }.Concat(runtimeNames).ToArray();
                    filterRuntime = selectedIndex < runtimes.Length ? runtimes[selectedIndex] : "";
                    break;
            }
            StateHasChanged();
        });
    }

    private void OnToolbarItemClicked(string actionId)
    {
        InvokeAsync(async () =>
        {
            switch (actionId)
            {
                case "refresh":
                    ToolbarService.SetItemEnabled("refresh", false);
                    try { await RefreshSimulators(forceRefresh: true); } finally { ToolbarService.SetItemEnabled("refresh", true); }
                    break;
                case "create": await ShowCreateDialog(); break;
            }
            StateHasChanged();
        });
    }
}
