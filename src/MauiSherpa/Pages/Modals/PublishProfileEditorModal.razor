    private string? existingProfileId;
    private List<PublishProfilePublisher> profilePublishers = new();
    private bool isSaving;

    // Publisher dialog
    private bool showPublisherDialog;
    private int publisherDialogStep; // 0 = pick provider, 1 = pick repo
    private SecretsPublisherConfig? dialogSelectedPublisher;

    // Apple
    private List<AppleConfigVM> appleConfigs = new();
    private List<AppleIdentity> appleIdentities = new();
