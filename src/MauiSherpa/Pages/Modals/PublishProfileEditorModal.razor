@page "/modal/publish-profile-editor"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.Requests.Apple
@using MauiSherpa.Pages.Forms
@using Shiny.Mediator
@inject HybridFormBridgeHolder BridgeHolder
@inject IAppleConnectService AppleService
@inject IAppleIdentityService AppleIdentityService
@inject IKeystoreService KeystoreService
@inject IManagedSecretsService ManagedSecrets
@inject ISecretsPublisherService PublisherService
@inject ILocalCertificateService LocalCertService
@inject IMediator Mediator
@implements IDisposable

<div class="profile-editor">
    <!-- Tabs -->
    <div class="editor-tabs">
        <button class="editor-tab @(activeTab == "general" ? "active" : "")"
                @onclick="@(() => activeTab = "general")">
            <i class="fa-solid fa-gear"></i> General
        </button>
        <button class="editor-tab @(activeTab == "apple" ? "active" : "")"
                @onclick="@(() => activeTab = "apple")">
            <i class="fa-brands fa-apple"></i> Apple
        </button>
        <button class="editor-tab @(activeTab == "android" ? "active" : "")"
                @onclick="@(() => activeTab = "android")">
            <i class="fa-brands fa-android"></i> Android
        </button>
        <button class="editor-tab @(activeTab == "secrets" ? "active" : "")"
                @onclick="@(() => activeTab = "secrets")">
            <i class="fa-solid fa-key"></i> Secrets
        </button>
    </div>

    <!-- Tab content -->
    <div class="tab-content">
        @if (activeTab == "general")
        {
            <div class="form-content">
                <div class="form-group">
                    <label>Profile Name</label>
                    <input type="text" class="form-control" @bind="profileName" @bind:event="oninput"
                           @bind:after="ValidateForm" placeholder="e.g., My App - Production" />
                </div>
                <div class="form-group">
                    <label>Description <span class="optional">(optional)</span></label>
                    <input type="text" class="form-control" @bind="profileDescription" @bind:event="oninput"
                           placeholder="Brief description of this profile" />
                </div>
                <div class="form-group">
                    <label>Default Publisher <span class="optional">(optional)</span></label>
                    <div class="form-hint">Choose a default CI/CD provider and repo for one-click publishing</div>
                    @if (publishers.Any())
                    {
                        <select class="form-control" @bind="selectedPublisherId">
                            <option value="">— Choose at publish time —</option>
                            @foreach (var pub in publishers)
                            {
                                <option value="@pub.Id">@pub.Name (@pub.ProviderId)</option>
                            }
                        </select>

                        @if (!string.IsNullOrEmpty(selectedPublisherId))
                        {
                            <div class="repo-picker" style="margin-top: 8px;">
                                <div class="search-box">
                                    <i class="fas fa-search"></i>
                                    <input type="text" @bind="repoSearch" @bind:event="oninput"
                                           placeholder="Search repositories..." />
                                    @if (!string.IsNullOrEmpty(repoSearch))
                                    {
                                        <button class="clear-search" @onclick="@(() => { repoSearch = ""; })">×</button>
                                    }
                                </div>
                                @if (loadingRepos)
                                {
                                    <div class="loading-hint"><i class="fa-solid fa-spinner fa-spin"></i> Loading repos...</div>
                                }
                                else if (filteredRepos.Any())
                                {
                                    <div class="selection-list compact">
                                        @foreach (var repo in filteredRepos.Take(20))
                                        {
                                            <label class="selection-item @(selectedRepoId == repo.Id ? "selected" : "")">
                                                <input type="radio" name="repo" checked="@(selectedRepoId == repo.Id)"
                                                       @onchange="@(() => { selectedRepoId = repo.Id; selectedRepoFullName = repo.FullName; ValidateForm(); })" />
                                                <div class="item-content">
                                                    <div class="item-name">@repo.FullName</div>
                                                    @if (!string.IsNullOrEmpty(repo.Description))
                                                    {
                                                        <div class="item-detail">@repo.Description</div>
                                                    }
                                                </div>
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="form-hint text-muted">No publishers configured. Configure in Settings first.</div>
                    }
                </div>
            </div>
        }

        @if (activeTab == "apple")
        {
            <div class="form-content">
                @if (appleWizardActive is not null)
                {
                    @* ── Inline Wizard ── *@
                    <div class="wizard">
                        <div class="step-indicator">
                            @for (int i = 1; i <= appleWizardActive.TotalSteps; i++)
                            {
                                var step = i;
                                <div class="step @(appleWizardActive.WizardStep >= step ? "active" : "") @(appleWizardActive.WizardStep > step ? "completed" : "")">
                                    <div class="step-number">@(appleWizardActive.WizardStep > step ? "✓" : step.ToString())</div>
                                    <div class="step-label">@appleWizardActive.GetStepLabel(step)</div>
                                </div>
                                @if (i < appleWizardActive.TotalSteps)
                                {
                                    <div class="step-line @(appleWizardActive.WizardStep > step ? "active" : "")"></div>
                                }
                            }
                        </div>

                        <div class="wizard-content">
                            @* Step 1: Platform *@
                            @if (appleWizardActive.WizardStep == 1)
                            {
                                <h4>Select Platform</h4>
                                <div class="option-cards">
                                    <div class="option-card @(appleWizardActive.Platform == ApplePlatformType.iOS ? "selected" : "")"
                                         @onclick="@(() => { appleWizardActive.Platform = ApplePlatformType.iOS; appleWizardActive.DistributionType = null; appleWizardActive.CertificateSerialNumber = null; appleWizardActive.InstallerCertSerialNumber = null; appleWizardActive.ProfileId = null; appleWizardActive.ProfileUuid = null; })">
                                        <i class="fa-brands fa-apple"></i>
                                        <div class="option-label">iOS</div>
                                        <div class="option-desc">iPhone &amp; iPad</div>
                                    </div>
                                    <div class="option-card @(appleWizardActive.Platform == ApplePlatformType.MacCatalyst ? "selected" : "")"
                                         @onclick="@(() => { appleWizardActive.Platform = ApplePlatformType.MacCatalyst; appleWizardActive.DistributionType = null; appleWizardActive.CertificateSerialNumber = null; appleWizardActive.InstallerCertSerialNumber = null; appleWizardActive.ProfileId = null; appleWizardActive.ProfileUuid = null; })">
                                        <i class="fa-solid fa-laptop"></i>
                                        <div class="option-label">Mac Catalyst</div>
                                        <div class="option-desc">iPad app on Mac</div>
                                    </div>
                                    <div class="option-card @(appleWizardActive.Platform == ApplePlatformType.macOS ? "selected" : "")"
                                         @onclick="@(() => { appleWizardActive.Platform = ApplePlatformType.macOS; appleWizardActive.DistributionType = null; appleWizardActive.CertificateSerialNumber = null; appleWizardActive.InstallerCertSerialNumber = null; appleWizardActive.ProfileId = null; appleWizardActive.ProfileUuid = null; })">
                                        <i class="fa-solid fa-display"></i>
                                        <div class="option-label">macOS</div>
                                        <div class="option-desc">Native Mac app</div>
                                    </div>
                                </div>
                            }

                            @* Step 2: Distribution Type *@
                            @if (appleWizardActive.WizardStep == 2)
                            {
                                <h4>Select Distribution Type</h4>
                                <div class="option-cards">
                                    @foreach (var dist in GetAvailableDistributionTypes())
                                    {
                                        <div class="option-card @(appleWizardActive.DistributionType == dist.Type ? "selected" : "")"
                                             @onclick="@(() => { appleWizardActive.DistributionType = dist.Type; appleWizardActive.CertificateSerialNumber = null; appleWizardActive.InstallerCertSerialNumber = null; appleWizardActive.ProfileId = null; appleWizardActive.ProfileUuid = null; })">
                                            <i class="@dist.Icon"></i>
                                            <div class="option-label">@dist.Name</div>
                                            <div class="option-desc">@dist.Description</div>
                                        </div>
                                    }
                                </div>
                            }

                            @* Step 3: Signing Certificate *@
                            @if (appleWizardActive.WizardStep == 3)
                            {
                                <h4>Signing Certificate <span class="optional-badge">Optional</span></h4>
                                @if (FilteredSigningCerts.Any())
                                {
                                    <div class="cert-list">
                                        @foreach (var cert in FilteredSigningCerts)
                                        {
                                            var hasKey = HasPrivateKey(cert);
                                            <label class="cert-item @(appleWizardActive.CertificateSerialNumber == cert.SerialNumber ? "selected" : "") @(!hasKey ? "no-key" : "")">
                                                <input type="radio" name="wizardSigningCert"
                                                       checked="@(appleWizardActive.CertificateSerialNumber == cert.SerialNumber)"
                                                       @onchange="@(() => appleWizardActive.CertificateSerialNumber = cert.SerialNumber)" />
                                                <div class="cert-info">
                                                    <div class="cert-name">@cert.Name</div>
                                                    <div class="cert-detail">
                                                        <span>@cert.CertificateType</span>
                                                        <span>Expires: @cert.ExpirationDate.ToString("MMM dd, yyyy")</span>
                                                    </div>
                                                </div>
                                                @if (hasKey)
                                                {
                                                    <span class="key-status has-key" title="Private key available"><i class="fa-solid fa-key"></i></span>
                                                }
                                                else
                                                {
                                                    <span class="key-status no-key" title="No private key locally"><i class="fa-solid fa-key"></i></span>
                                                }
                                            </label>
                                        }
                                    </div>
                                    @if (appleWizardActive.CertificateSerialNumber is not null)
                                    {
                                        <button class="btn-action small" @onclick="@(() => appleWizardActive.CertificateSerialNumber = null)">
                                            <i class="fa-solid fa-times"></i> Clear Selection
                                        </button>
                                    }
                                }
                                else
                                {
                                    <div class="empty-list">
                                        <i class="fa-solid fa-inbox"></i>
                                        <span>No matching certificates found</span>
                                    </div>
                                }
                            }

                            @* Step 4+ (conditional): Installer Certificate — only for Mac Direct *@
                            @if (appleWizardActive.NeedsInstallerStep && appleWizardActive.WizardStep == 4)
                            {
                                <h4>Installer Certificate <span class="optional-badge">Optional</span></h4>
                                @if (FilteredInstallerCerts.Any())
                                {
                                    <div class="cert-list">
                                        @foreach (var cert in FilteredInstallerCerts)
                                        {
                                            var hasKey = HasPrivateKey(cert);
                                            <label class="cert-item @(appleWizardActive.InstallerCertSerialNumber == cert.SerialNumber ? "selected" : "") @(!hasKey ? "no-key" : "")">
                                                <input type="radio" name="wizardInstallerCert"
                                                       checked="@(appleWizardActive.InstallerCertSerialNumber == cert.SerialNumber)"
                                                       @onchange="@(() => appleWizardActive.InstallerCertSerialNumber = cert.SerialNumber)" />
                                                <div class="cert-info">
                                                    <div class="cert-name">@cert.Name</div>
                                                    <div class="cert-detail">
                                                        <span>@cert.CertificateType</span>
                                                        <span>Expires: @cert.ExpirationDate.ToString("MMM dd, yyyy")</span>
                                                    </div>
                                                </div>
                                                @if (hasKey)
                                                {
                                                    <span class="key-status has-key" title="Private key available"><i class="fa-solid fa-key"></i></span>
                                                }
                                                else
                                                {
                                                    <span class="key-status no-key" title="No private key locally"><i class="fa-solid fa-key"></i></span>
                                                }
                                            </label>
                                        }
                                    </div>
                                    @if (appleWizardActive.InstallerCertSerialNumber is not null)
                                    {
                                        <button class="btn-action small" @onclick="@(() => appleWizardActive.InstallerCertSerialNumber = null)">
                                            <i class="fa-solid fa-times"></i> Clear Selection
                                        </button>
                                    }
                                }
                                else
                                {
                                    <div class="empty-list">
                                        <i class="fa-solid fa-inbox"></i>
                                        <span>No installer certificates found</span>
                                    </div>
                                }
                            }

                            @* Profile step — computed position varies *@
                            @{
                                var profileStep = appleWizardActive.NeedsInstallerStep ? 5 : 4;
                                var notarizationStep = profileStep + (appleWizardActive.NeedsProfileStep ? 1 : 0);
                            }
                            @if (appleWizardActive.NeedsProfileStep && appleWizardActive.WizardStep == profileStep)
                            {
                                <h4>Provisioning Profile <span class="optional-badge">Optional</span></h4>
                                @if (FilteredProfiles.Any())
                                {
                                    <div class="cert-list">
                                        @foreach (var prof in FilteredProfiles)
                                        {
                                            <label class="cert-item @(appleWizardActive.ProfileId == prof.Id ? "selected" : "")">
                                                <input type="radio" name="wizardProfile"
                                                       checked="@(appleWizardActive.ProfileId == prof.Id)"
                                                       @onchange="@(() => { appleWizardActive.ProfileId = prof.Id; appleWizardActive.ProfileUuid = prof.Uuid; })" />
                                                <div class="cert-info">
                                                    <div class="cert-name">@prof.Name</div>
                                                    <div class="cert-detail">
                                                        <span>@prof.ProfileType</span>
                                                        <span>Expires: @prof.ExpirationDate.ToString("MMM dd, yyyy")</span>
                                                    </div>
                                                </div>
                                            </label>
                                        }
                                    </div>
                                    @if (appleWizardActive.ProfileId is not null)
                                    {
                                        <button class="btn-action small" @onclick="@(() => { appleWizardActive.ProfileId = null; appleWizardActive.ProfileUuid = null; })">
                                            <i class="fa-solid fa-times"></i> Clear Selection
                                        </button>
                                    }
                                }
                                else
                                {
                                    <div class="empty-list">
                                        <i class="fa-solid fa-inbox"></i>
                                        <span>No matching provisioning profiles found</span>
                                    </div>
                                }
                            }

                            @* Notarization step — only for Direct *@
                            @if (appleWizardActive.NeedsNotarizationStep && appleWizardActive.WizardStep == notarizationStep)
                            {
                                <h4>Notarization Credentials <span class="optional-badge">Optional</span></h4>
                                <p class="step-description">Link managed secrets to notarization credentials, or skip to omit.</p>
                                <div class="notarization-fields">
                                    <div class="form-field">
                                        <label>Apple ID</label>
                                        <select class="form-control compact" @bind="appleWizardActive.NotarizationAppleIdSecretKey">
                                            <option value="">— None —</option>
                                            @foreach (var secret in managedSecrets)
                                            {
                                                <option value="@secret.Key">@secret.Key</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-field">
                                        <label>App-Specific Password</label>
                                        <select class="form-control compact" @bind="appleWizardActive.NotarizationPasswordSecretKey">
                                            <option value="">— None —</option>
                                            @foreach (var secret in managedSecrets)
                                            {
                                                <option value="@secret.Key">@secret.Key</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-field">
                                        <label>Team ID</label>
                                        <select class="form-control compact" @bind="appleWizardActive.NotarizationTeamIdSecretKey">
                                            <option value="">— None —</option>
                                            @foreach (var secret in managedSecrets)
                                            {
                                                <option value="@secret.Key">@secret.Key</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <label class="config-toggle" style="margin-top: 0.5rem;">
                                    <input type="checkbox" @bind="appleWizardActive.IncludeNotarization" />
                                    <span>Include notarization in key mappings</span>
                                </label>
                            }
                        </div>

                        <div class="wizard-footer">
                            @if (appleWizardActive.WizardStep > 1)
                            {
                                <button class="btn-action small" @onclick="AppleWizardBack">
                                    <i class="fa-solid fa-arrow-left"></i> Back
                                </button>
                            }
                            <div class="spacer"></div>
                            <button class="btn-action small" @onclick="CancelAppleWizard">Cancel</button>
                            @if (appleWizardActive.WizardStep < appleWizardActive.TotalSteps)
                            {
                                <button class="btn-action small primary" @onclick="AppleWizardNext" disabled="@(!CanAppleWizardProceed())">
                                    Next <i class="fa-solid fa-arrow-right"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn-action small primary" @onclick="FinishAppleWizard" disabled="@(!CanAppleWizardProceed())">
                                    <i class="fa-solid fa-check"></i> Done
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @* ── Config List + Add Button ── *@
                    <div class="section-header">
                        <span>Apple Configurations</span>
                        <button class="btn-action small" @onclick="StartAppleWizard">
                            <i class="fa-solid fa-plus"></i> Add Config
                        </button>
                    </div>

                    @if (!appleConfigs.Any())
                    {
                        <div class="empty-state">
                            <i class="fa-brands fa-apple"></i>
                            <p>No Apple configurations yet</p>
                            <button class="btn-action small" @onclick="StartAppleWizard">Add Apple Config</button>
                        </div>
                    }
                    else
                    {
                        @foreach (var config in appleConfigs)
                        {
                            <div class="config-card">
                                <div class="config-header">
                                    <div class="config-badges">
                                        @if (config.Platform is not null)
                                        {
                                            <span class="badge platform">@config.PlatformLabel</span>
                                        }
                                        @if (config.DistributionType is not null)
                                        {
                                            <span class="badge distribution">@config.DistributionLabel</span>
                                        }
                                        <span class="config-label-text">@config.Label</span>
                                    </div>
                                    <div class="config-actions">
                                        <button class="btn-icon-action" @onclick="@(() => EditAppleConfig(config))" title="Edit">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        <button class="btn-icon-action danger" @onclick="@(() => appleConfigs.Remove(config))" title="Remove">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="config-summary">
                                    @if (!string.IsNullOrEmpty(config.CertificateSerialNumber))
                                    {
                                        var cert = certificates.FirstOrDefault(c => c.SerialNumber == config.CertificateSerialNumber);
                                        <div class="summary-item"><i class="fa-solid fa-stamp"></i> @(cert?.Name ?? config.CertificateSerialNumber)</div>
                                    }
                                    @if (!string.IsNullOrEmpty(config.InstallerCertSerialNumber))
                                    {
                                        var cert = certificates.FirstOrDefault(c => c.SerialNumber == config.InstallerCertSerialNumber);
                                        <div class="summary-item"><i class="fa-solid fa-box"></i> @(cert?.Name ?? "Installer")</div>
                                    }
                                    @if (!string.IsNullOrEmpty(config.ProfileId))
                                    {
                                        var prof = profiles.FirstOrDefault(p => p.Id == config.ProfileId);
                                        <div class="summary-item"><i class="fa-solid fa-file-signature"></i> @(prof?.Name ?? config.ProfileId)</div>
                                    }
                                    @if (config.IncludeNotarization)
                                    {
                                        <div class="summary-item"><i class="fa-solid fa-shield-halved"></i> Notarization</div>
                                    }
                                </div>
                                @* Key mappings (collapsible) *@
                                @{
                                    var keys = config.GetDefaultKeys();
                                    if (keys.Any())
                                    {
                                        <details class="key-mappings-section">
                                            <summary><i class="fa-solid fa-key"></i> Key Mappings (@keys.Count keys)</summary>
                                            <div class="key-mappings">
                                                @foreach (var defaultKey in keys)
                                                {
                                                    <div class="key-mapping-row">
                                                        <div class="key-label">@defaultKey</div>
                                                        <div class="key-destinations">
                                                            @{
                                                                var destinations = config.KeyMappings.GetValueOrDefault(defaultKey) ?? new List<string>();
                                                            }
                                                            @foreach (var dest in destinations)
                                                            {
                                                                <div class="destination-chip">
                                                                    <input type="text" class="dest-input" value="@dest"
                                                                           @onchange="@(e => UpdateDestination(config.KeyMappings, defaultKey, dest, e.Value?.ToString() ?? ""))" />
                                                                    @if (destinations.Count > 1)
                                                                    {
                                                                        <button class="chip-remove" @onclick="@(() => RemoveDestination(config.KeyMappings, defaultKey, dest))">×</button>
                                                                    }
                                                                </div>
                                                            }
                                                            <button class="btn-add-dest" @onclick="@(() => AddDestination(config.KeyMappings, defaultKey))" title="Add another destination">
                                                                <i class="fa-solid fa-plus"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </details>
                                    }
                                }
                            </div>
                        }
                    }
                }
            </div>
        }

        @if (activeTab == "android")
        {
            <div class="form-content">
                <div class="section-header">
                    <span>Android Configurations</span>
                    <button class="btn-action small" @onclick="AddAndroidConfig">
                        <i class="fa-solid fa-plus"></i> Add Config
                    </button>
                </div>

                @if (!androidConfigs.Any())
                {
                    <div class="empty-state">
                        <i class="fa-brands fa-android"></i>
                        <p>No Android configurations yet</p>
                        <button class="btn-action small" @onclick="AddAndroidConfig">Add Android Config</button>
                    </div>
                }
                else
                {
                    @foreach (var config in androidConfigs)
                    {
                        <div class="config-card">
                            <div class="config-header">
                                <input type="text" class="config-label-input" @bind="config.Label" @bind:event="oninput"
                                       placeholder="e.g., PlayStore, Debug" />
                                <button class="btn-icon-action danger" @onclick="@(() => androidConfigs.Remove(config))"
                                        title="Remove config">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                            <div class="config-body">
                                <!-- Keystore -->
                                <div class="config-item">
                                    <label class="config-toggle">
                                        <input type="checkbox" checked="@(!string.IsNullOrEmpty(config.KeystoreId))"
                                               @onchange="@(e => { if (!(bool)(e.Value ?? false)) config.KeystoreId = null; })" />
                                        <span>Keystore</span>
                                    </label>
                                    @if (!string.IsNullOrEmpty(config.KeystoreId) || config.ShowKeystorePicker)
                                    {
                                        <select class="form-control compact" @bind="config.KeystoreId">
                                            <option value="">— Select —</option>
                                            @foreach (var ks in keystores)
                                            {
                                                <option value="@ks.Id">@ks.Alias (@ks.KeystoreType)</option>
                                            }
                                        </select>
                                    }
                                </div>

                                <!-- Key Mappings -->
                                @if (config.HasAnyItems)
                                {
                                    <details class="key-mappings-section">
                                        <summary><i class="fa-solid fa-key"></i> Key Mappings (@config.GetDefaultKeys().Count keys)</summary>
                                        <div class="key-mappings">
                                            @foreach (var defaultKey in config.GetDefaultKeys())
                                            {
                                                <div class="key-mapping-row">
                                                    <div class="key-label">@defaultKey</div>
                                                    <div class="key-destinations">
                                                        @{
                                                            var destinations = config.KeyMappings.GetValueOrDefault(defaultKey) ?? new List<string>();
                                                        }
                                                        @foreach (var dest in destinations)
                                                        {
                                                            <div class="destination-chip">
                                                                <input type="text" class="dest-input" value="@dest"
                                                                       @onchange="@(e => UpdateDestination(config.KeyMappings, defaultKey, dest, e.Value?.ToString() ?? ""))" />
                                                                @if (destinations.Count > 1)
                                                                {
                                                                    <button class="chip-remove" @onclick="@(() => RemoveDestination(config.KeyMappings, defaultKey, dest))">×</button>
                                                                }
                                                            </div>
                                                        }
                                                        <button class="btn-add-dest" @onclick="@(() => AddDestination(config.KeyMappings, defaultKey))"
                                                                title="Add another destination">
                                                            <i class="fa-solid fa-plus"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </details>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }

        @if (activeTab == "secrets")
        {
            <div class="form-content">
                <div class="section-header">
                    <span>Secret Mappings</span>
                    <button class="btn-action small" @onclick="@(() => showSecretPicker = true)">
                        <i class="fa-solid fa-plus"></i> Add Secret
                    </button>
                </div>

                @if (showSecretPicker)
                {
                    <div class="secret-picker-card">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" @bind="secretSearch" @bind:event="oninput" placeholder="Search managed secrets..." />
                            @if (!string.IsNullOrEmpty(secretSearch))
                            {
                                <button class="clear-search" @onclick="@(() => secretSearch = "")">×</button>
                            }
                        </div>
                        <div class="selection-list compact">
                            @foreach (var secret in filteredManagedSecrets)
                            {
                                <label class="selection-item" @onclick="@(() => AddSecretMapping(secret.Key))">
                                    <div class="item-content">
                                        <div class="item-name mono">@secret.Key</div>
                                        @if (!string.IsNullOrEmpty(secret.Description))
                                        {
                                            <div class="item-detail">@secret.Description</div>
                                        }
                                    </div>
                                </label>
                            }
                            @if (!filteredManagedSecrets.Any())
                            {
                                <div class="empty-hint">No matching secrets</div>
                            }
                        </div>
                        <button class="btn-text" @onclick="@(() => showSecretPicker = false)">Cancel</button>
                    </div>
                }

                @if (!secretMappings.Any() && !showSecretPicker)
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-key"></i>
                        <p>No secret mappings yet</p>
                        <button class="btn-action small" @onclick="@(() => showSecretPicker = true)">Add Secret Mapping</button>
                    </div>
                }
                else
                {
                    @foreach (var mapping in secretMappings)
                    {
                        <div class="config-card">
                            <div class="config-header">
                                <span class="mono">@mapping.SourceKey</span>
                                <button class="btn-icon-action danger" @onclick="@(() => secretMappings.Remove(mapping))"
                                        title="Remove mapping">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                            <div class="config-body">
                                <div class="key-mapping-row">
                                    <div class="key-label">Destination keys:</div>
                                    <div class="key-destinations">
                                        @foreach (var dest in mapping.DestinationKeys)
                                        {
                                            <div class="destination-chip">
                                                <input type="text" class="dest-input" value="@dest"
                                                       @onchange="@(e => { var idx = mapping.DestinationKeys.IndexOf(dest); if (idx >= 0) mapping.DestinationKeys[idx] = e.Value?.ToString() ?? ""; })" />
                                                @if (mapping.DestinationKeys.Count > 1)
                                                {
                                                    <button class="chip-remove" @onclick="@(() => mapping.DestinationKeys.Remove(dest))">×</button>
                                                }
                                            </div>
                                        }
                                        <button class="btn-add-dest" @onclick="@(() => mapping.DestinationKeys.Add(mapping.SourceKey + "_" + (mapping.DestinationKeys.Count + 1)))"
                                                title="Add another destination">
                                            <i class="fa-solid fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

