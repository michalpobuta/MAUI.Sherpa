    private async Task ApplyImportedBackupAsync(BackupImportResult importResult)
    {
        var settings = importResult.Settings;
        var selection = importResult.Selection;

        if (selection.IncludePreferences)
        {
            await EncryptedSettings.UpdateSettingsAsync(existing => existing with
            {
                Preferences = settings.Preferences
            });

            ViewModel.Theme = settings.Preferences.Theme;
            ViewModel.FontScale = settings.Preferences.FontScale;
            demoMode = settings.Preferences.DemoMode;
            ThemeService.SetTheme(ViewModel.Theme);
            ThemeService.SetFontScale(ViewModel.FontScale);
        }

        foreach (var identity in settings.AppleIdentities)
        {
            await AppleIdentityService.SaveIdentityAsync(new AppleIdentity(
                Id: identity.Id,
                Name: identity.Name,
                KeyId: identity.KeyId,
                IssuerId: identity.IssuerId,
                P8KeyPath: null,
                P8KeyContent: identity.P8Content));
        }

        var selectedIdentityId = IdentityState.SelectedIdentity?.Id;
        if (!string.IsNullOrEmpty(selectedIdentityId))
        {
            var refreshedIdentity = await AppleIdentityService.GetIdentityAsync(selectedIdentityId);
            IdentityState.SetSelectedIdentity(refreshedIdentity);
        }

        if (settings.CloudProviders.Count > 0)
        {
            await CloudSecretsService.InitializeAsync();
            foreach (var provider in settings.CloudProviders)
            {
                await CloudSecretsService.SaveProviderAsync(new CloudSecretsProviderConfig(
                    provider.Id,
                    provider.Name,
                    provider.ProviderType,
                    new Dictionary<string, string>(provider.Settings)));
            }

            if (!string.IsNullOrEmpty(settings.ActiveCloudProviderId) &&
                settings.CloudProviders.Any(provider => provider.Id == settings.ActiveCloudProviderId))
            {
                await CloudSecretsService.SetActiveProviderAsync(settings.ActiveCloudProviderId);
            }
        }

        foreach (var publisher in settings.SecretsPublishers)
        {
            await SecretsPublisherService.SavePublisherAsync(new SecretsPublisherConfig(
                publisher.Id,
                publisher.ProviderId,
                publisher.Name,
                new Dictionary<string, string>(publisher.Settings)));
        }

        foreach (var googleIdentity in settings.GoogleIdentities)
        {
            await GoogleIdentityService.SaveIdentityAsync(new GoogleIdentity(
                Id: googleIdentity.Id,
                Name: googleIdentity.Name,
                ProjectId: googleIdentity.ProjectId,
                ClientEmail: googleIdentity.ClientEmail,
                ServiceAccountJsonPath: null,
                ServiceAccountJson: googleIdentity.ServiceAccountJson));
        }

        foreach (var pushProject in settings.PushProjects)
        {
            await PushProjectService.SaveProjectAsync(pushProject);
        }

        await LoadGoogleIdentities();
    }

    // === Update Dialog ===

    private void ShowUpdateDialog()
    {
        showUpdateDialog = true;
    }

    private async Task HandleSettingsUpdateAccept()
    {
        if (updateResult?.LatestRelease?.HtmlUrl is { Length: > 0 } url)
        {
            try { await AppLauncher.OpenAsync(new Uri(url)); } catch { }
        }
        showUpdateDialog = false;
    }

    private Task HandleSettingsUpdateDecline()
    {
        showUpdateDialog = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleSettingsAutoUpdate()
    {
        if (updateResult?.LatestRelease == null) return;
        try
        {
            var progress = new Progress<(double Percent, string Message)>(update =>
            {
                updateModal?.UpdateProgress(update.Percent, update.Message);
            });
            await UpdateService.DownloadAndApplyUpdateAsync(updateResult.LatestRelease, progress);
        }
        catch (Exception ex)
        {
            await AlertService.ShowAlertAsync("Update Failed", ex.Message);
            showUpdateDialog = false;
            StateHasChanged();
        }
    }
