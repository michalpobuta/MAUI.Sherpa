@using MauiSherpa.Core.Models.DevFlow
@using MauiSherpa.Core.Services
@inject IJSRuntime JS
@implements IDisposable

<div class="tree-layout">
    <!-- Left: Screenshot -->
    <div class="tree-screenshot-pane" style="width: @(screenshotPaneWidth)px;">
        <div class="pane-header">
            <span>Screenshot</span>
            <div class="pane-actions">
                <button class="btn-icon @(inspectMode ? "inspect-active" : "")"
                        @onclick="() => { inspectMode = !inspectMode; }"
                        title="@(inspectMode ? "Exit inspect mode" : "Inspect element (click on screenshot)")">
                    <i class="fas fa-crosshairs"></i>
                </button>
                <button class="btn-icon @(hitTestDebug ? "inspect-active" : "")"
                        @onclick="() => { hitTestDebug = !hitTestDebug; }"
                        title="@(hitTestDebug ? "Hide hit test debug info" : "Show hit test debug info")">
                    <i class="fas fa-bug"></i>
                </button>
                <select @bind="autoRefreshInterval" @bind:after="OnAutoRefreshChanged" class="auto-refresh-select">
                    <option value="0">Manual</option>
                    <option value="1">1s</option>
                    <option value="2">2s</option>
                    <option value="5">5s</option>
                </select>
                <button class="btn-icon" @onclick="() => RefreshScreenshot()" title="Refresh screenshot">
                    <i class="fas fa-camera"></i>
                </button>
            </div>
        </div>
        <div class="screenshot-container">
            @if (screenshotData != null)
            {
                <div class="screenshot-wrapper" @onclick="OnScreenshotClick">
                    <img src="@($"data:image/png;base64,{screenshotData}")" alt="App screenshot"
                         class="screenshot-img @(inspectMode ? "inspect-cursor" : "")" />
                    @if (locateElementId != null && (selectedElement?.Bounds != null || selectedElement?.WindowBounds != null) && screenshotData != null)
                    {
                        @RenderHighlightOverlay
                    }
                </div>
            }
            else
            {
                <div class="screenshot-placeholder">
                    <i class="fas fa-image"></i>
                    <span>Click refresh to capture</span>
                </div>
            }
        </div>
        @if (hitTestDebug && hitTestDebugInfo != null)
        {
            <div class="hit-test-debug">
                <span class="hit-test-text">@hitTestDebugInfo</span>
                <button class="hit-test-copy" @onclick="CopyHitTestDebug" title="Copy"><i class="fas fa-copy"></i></button>
            </div>
        }
    </div>

    <div class="resize-handle" @onmousedown="@(e => StartResize(e, "left"))" @onmousedown:preventDefault></div>

    <!-- Center: Tree View -->
    <div class="tree-view-pane">
        <div class="pane-header">
            <span>Visual Tree</span>
            <div class="pane-actions">
                <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Filter..." class="tree-search" />
                <button class="btn-icon" @onclick="ExpandAll" title="Expand all">
                    <i class="fas fa-angles-down"></i>
                </button>
                <button class="btn-icon" @onclick="CollapseAll" title="Collapse all">
                    <i class="fas fa-angles-up"></i>
                </button>
                <button class="btn-icon" @onclick="RefreshTree" title="Refresh tree">
                    <i class="fas @(isLoadingTree ? "fa-spinner fa-spin" : "fa-sync-alt")"></i>
                </button>
            </div>
        </div>
        <div class="tree-container">
            @if (treeItems.Count > 0)
            {
                @for (int i = 0; i < treeItems.Count; i++)
                {
                    var windowIndex = i;
                    var item = treeItems[i];
                    @if (treeItems.Count > 1)
                    {
                        <div class="window-header @(selectedWindowIndex == windowIndex ? "active" : "")">
                            <i class="fas fa-window-maximize"></i>
                            Window @windowIndex: @item.Type
                        </div>
                    }
                    @RenderNode(item, 0, new List<bool>())
                }
            }
            else if (isLoadingTree)
            {
                <div class="tree-loading"><i class="fas fa-spinner fa-spin"></i> Loading tree...</div>
            }
            else
            {
                <div class="tree-empty">No elements found</div>
            }
        </div>
    </div>

    <div class="resize-handle" @onmousedown="@(e => StartResize(e, "right"))" @onmousedown:preventDefault></div>

    <!-- Right: Properties -->
    <div class="tree-props-pane" style="width: @(propsPaneWidth)px;">
        <div class="pane-header">
            <span>Properties</span>
            @if (selectedElement != null)
            {
                @if (isLoadingProps)
                {
                    <i class="fas fa-spinner fa-spin prop-loading-icon"></i>
                }
                <button class="btn-icon prop-refresh-btn" @onclick="RefreshProperties" title="Refresh properties">
                    <i class="fas fa-sync-alt"></i>
                </button>
            }
        </div>
        <div class="props-container">
            @if (selectedElement != null)
            {
                <!-- Element identity -->
                <div class="prop-section">
                    <div class="prop-group-title">Element</div>
                    @{ var ns = selectedElement.FullType.Contains('.') ? selectedElement.FullType[..selectedElement.FullType.LastIndexOf('.')] : ""; }
                    @if (!string.IsNullOrEmpty(ns))
                    {
                        <div class="prop-row">
                            <span class="prop-key">Namespace</span>
                            <span class="prop-value mono">@ns</span>
                        </div>
                    }
                    <div class="prop-row">
                        <span class="prop-key">Type</span>
                        <span class="prop-value">@selectedElement.Type</span>
                    </div>
                    <div class="prop-row">
                        <span class="prop-key">ID</span>
                        <span class="prop-value mono">@selectedElement.Id</span>
                    </div>
                    @if (selectedElement.Bounds != null)
                    {
                        <div class="prop-row">
                            <span class="prop-key">Position</span>
                            <span class="prop-value">@($"{selectedElement.Bounds.X:F0}, {selectedElement.Bounds.Y:F0}")</span>
                        </div>
                        <div class="prop-row">
                            <span class="prop-key">Size</span>
                            <span class="prop-value">@($"{selectedElement.Bounds.Width:F0} × {selectedElement.Bounds.Height:F0}")</span>
                        </div>
                    }
                    @if (selectedElement.WindowBounds != null)
                    {
                        <div class="prop-row">
                            <span class="prop-key">Window</span>
                            <span class="prop-value">@($"{selectedElement.WindowBounds.X:F0}, {selectedElement.WindowBounds.Y:F0}  {selectedElement.WindowBounds.Width:F0} × {selectedElement.WindowBounds.Height:F0}")</span>
                        </div>
                    }
                </div>

                <!-- Gestures -->
                @if (selectedElement.Gestures?.Count > 0)
                {
                    <div class="prop-section">
                        <div class="prop-section-title">Gestures</div>
                        @foreach (var gesture in selectedElement.Gestures)
                        {
                            <div class="prop-row"><span class="prop-value">@gesture</span></div>
                        }
                    </div>
                }

                @if (fetchedProperties.Count > 0)
                {
                    @foreach (var group in fetchedProperties.GroupBy(p => p.Meta.Group).OrderBy(g => Array.IndexOf(GroupOrder, g.Key)))
                    {
                        <div class="prop-section" @key="group.Key">
                            <div class="prop-group-title">@group.Key</div>
                            @foreach (var prop in group)
                            {
                                <div @key="prop.Name">
                                    @RenderPropertyEditor(prop)
                                </div>
                            }
                            @if (group.Key == "Behavior")
                            {
                                <div class="prop-row">
                                    <span class="prop-key">Focused</span>
                                    <span class="prop-value @(selectedElement.IsFocused ? "val-true" : "val-false")">
                                        @selectedElement.IsFocused
                                        @if (!selectedElement.IsFocused)
                                        {
                                            <button class="btn-focus" @onclick="FocusSelected" title="Focus this element">
                                                <i class="fas fa-crosshairs"></i>
                                            </button>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    }
                }
                else if (!isLoadingProps)
                {
                    <div class="prop-section">
                        <div class="prop-row"><span class="prop-value" style="color: var(--text-tertiary);">No properties found</span></div>
                    </div>
                }

                <!-- Custom property query -->
                <div class="prop-section">
                    <div class="prop-section-title">Query Property</div>
                    <div class="prop-row">
                        <input type="text" @bind="customPropertyName" @bind:event="oninput" @onkeydown="OnCustomPropertyKeyDown"
                               placeholder="PropertyName" class="prop-custom-input" />
                        <button class="btn-icon" @onclick="FetchCustomProperty" title="Fetch property">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>

                <!-- Native -->
                @if (selectedElement.NativeType != null)
                {
                    <div class="prop-section">
                        <div class="prop-section-title">Native (@selectedElement.NativeType)</div>
                        @if (selectedElement.NativeProperties != null)
                        {
                            @foreach (var kvp in selectedElement.NativeProperties)
                            {
                                <div class="prop-row">
                                    <span class="prop-key">@kvp.Key</span>
                                    <span class="prop-value">@(kvp.Value ?? "null")</span>
                                </div>
                            }
                        }
                    </div>
                }
            }
            else
            {
                <div class="props-empty">Select an element in the tree to view its properties</div>
            }
        </div>
    </div>
</div>

@if (isResizing)
{
    <div class="resize-overlay"
         @onmousemove="OnResizeMove" @onmousemove:preventDefault
         @onmouseup="StopResize" @onmouseup:preventDefault></div>
}

@code {
    [Parameter] public DevFlowAgentClient Client { get; set; } = null!;

    private List<DevFlowElementInfo> treeItems = new();
    private DevFlowElementInfo? selectedElement;
    private string? selectedElementId;
    private int? selectedWindowIndex;
    private HashSet<string> expandedNodes = new();
    private string searchQuery = "";
    private string? screenshotData;
    private bool isLoadingTree;
    private bool isLoadingProps;
    private int autoRefreshInterval;
    private Timer? _screenshotTimer;
    private bool inspectMode;
    private bool hitTestDebug;
    private string? hitTestDebugInfo;
    private bool _syncingRefresh;
    private string? overlayStyle;
    private string? locateElementId;
    private string? editingProperty;
    private string editValue = "";
    private ElementReference editInput;
    private List<PropertyEntry> fetchedProperties = new();
    private string customPropertyName = "";
    private List<GradientStop> gradientStops = new();
    private int? selectedStopIndex;
    private double gradientAngle = 90;
    private bool isDraggingStop;
    private ElementReference gradientTrackRef;
    private Dictionary<string, string> brushValueCache = new();

    private record PropertyEntry(string Name, string? Value, PropertyMeta Meta);

    private class GradientStop
    {
        public string Color { get; set; } = "#ffffff";
        public double Offset { get; set; }
        public double Opacity { get; set; } = 1.0;
    }

    // --- Property Metadata Registry ---

    private enum EditorType { Text, Boolean, Enum, Color, Thickness, Number, Brush }

    private record PropertyMeta(
        EditorType Editor,
        string Group = "Other",
        string[]? EnumValues = null,
        double? NumMin = null, double? NumMax = null, double NumStep = 1,
        bool IsDouble = false,
        int SortOrder = 100,
        string? DefaultValue = null);

    private static readonly Dictionary<string, PropertyMeta> PropertyRegistry = new(StringComparer.OrdinalIgnoreCase)
    {
        // --- Appearance ---
        ["Background"] = new(EditorType.Brush, "Appearance"),
        ["TextColor"] = new(EditorType.Color, "Appearance"),
        ["PlaceholderColor"] = new(EditorType.Color, "Appearance"),
        ["BorderColor"] = new(EditorType.Color, "Appearance"),
        ["Color"] = new(EditorType.Color, "Appearance"),
        ["BarBackgroundColor"] = new(EditorType.Color, "Appearance"),
        ["BarTextColor"] = new(EditorType.Color, "Appearance"),
        ["Stroke"] = new(EditorType.Brush, "Appearance"),
        ["Fill"] = new(EditorType.Brush, "Appearance"),
        ["Opacity"] = new(EditorType.Number, "Appearance", NumMin: 0, NumMax: 1, NumStep: 0.05, IsDouble: true),
        ["FontSize"] = new(EditorType.Number, "Appearance", NumMin: 1, NumMax: 200, NumStep: 1, IsDouble: true),
        ["FontFamily"] = new(EditorType.Text, "Appearance"),
        ["FontAttributes"] = new(EditorType.Enum, "Appearance", EnumValues: new[] { "None", "Bold", "Italic" }),
        ["TextDecorations"] = new(EditorType.Enum, "Appearance", EnumValues: new[] { "None", "Underline", "Strikethrough" }),
        ["StyleClass"] = new(EditorType.Text, "Appearance"),
        ["CornerRadius"] = new(EditorType.Number, "Appearance", NumMin: 0, NumMax: 500, NumStep: 1),

        // --- Layout ---
        ["Margin"] = new(EditorType.Thickness, "Layout", SortOrder: 1),
        ["Padding"] = new(EditorType.Thickness, "Layout", SortOrder: 2),
        ["HorizontalOptions"] = new(EditorType.Enum, "Layout", SortOrder: 3,
            EnumValues: new[] { "Start", "Center", "End", "Fill", "StartAndExpand", "CenterAndExpand", "EndAndExpand", "FillAndExpand" }),
        ["VerticalOptions"] = new(EditorType.Enum, "Layout", SortOrder: 4,
            EnumValues: new[] { "Start", "Center", "End", "Fill", "StartAndExpand", "CenterAndExpand", "EndAndExpand", "FillAndExpand" }),
        ["WidthRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 5),
        ["HeightRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 6),
        ["MinimumWidthRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 7, DefaultValue: "-1"),
        ["MinimumHeightRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 8, DefaultValue: "-1"),
        ["MaximumWidthRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 9, DefaultValue: "Infinity"),
        ["MaximumHeightRequest"] = new(EditorType.Number, "Layout", NumMin: -1, NumMax: 10000, NumStep: 1, IsDouble: true, SortOrder: 10, DefaultValue: "Infinity"),
        ["HorizontalTextAlignment"] = new(EditorType.Enum, "Layout", SortOrder: 11,
            EnumValues: new[] { "Start", "Center", "End" }),
        ["VerticalTextAlignment"] = new(EditorType.Enum, "Layout", SortOrder: 12,
            EnumValues: new[] { "Start", "Center", "End" }),
        ["LineBreakMode"] = new(EditorType.Enum, "Layout", SortOrder: 13,
            EnumValues: new[] { "NoWrap", "WordWrap", "CharacterWrap", "HeadTruncation", "TailTruncation", "MiddleTruncation" }),
        ["Spacing"] = new(EditorType.Number, "Layout", NumMin: 0, NumMax: 1000, NumStep: 1, IsDouble: true, SortOrder: 14),

        // --- Transform ---
        ["Rotation"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 360, NumStep: 1, IsDouble: true),
        ["RotationX"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 360, NumStep: 1, IsDouble: true),
        ["RotationY"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 360, NumStep: 1, IsDouble: true),
        ["Scale"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 10, NumStep: 0.1, IsDouble: true),
        ["ScaleX"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 10, NumStep: 0.1, IsDouble: true),
        ["ScaleY"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 10, NumStep: 0.1, IsDouble: true),
        ["TranslationX"] = new(EditorType.Number, "Transform", NumMin: -10000, NumMax: 10000, NumStep: 1, IsDouble: true),
        ["TranslationY"] = new(EditorType.Number, "Transform", NumMin: -10000, NumMax: 10000, NumStep: 1, IsDouble: true),
        ["AnchorX"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 1, NumStep: 0.1, IsDouble: true),
        ["AnchorY"] = new(EditorType.Number, "Transform", NumMin: 0, NumMax: 1, NumStep: 0.1, IsDouble: true),

        // --- Behavior ---
        ["IsVisible"] = new(EditorType.Boolean, "Appearance", SortOrder: -2),
        ["IsEnabled"] = new(EditorType.Boolean, "Appearance", SortOrder: -1),
        ["InputTransparent"] = new(EditorType.Boolean, "Behavior"),
        ["IsReadOnly"] = new(EditorType.Boolean, "Behavior"),
        ["IsSpellCheckEnabled"] = new(EditorType.Boolean, "Behavior"),
        ["IsTextPredictionEnabled"] = new(EditorType.Boolean, "Behavior"),
        ["ZIndex"] = new(EditorType.Number, "Behavior", NumMin: -1000, NumMax: 1000, NumStep: 1),
        ["FlowDirection"] = new(EditorType.Enum, "Behavior",
            EnumValues: new[] { "MatchParent", "LeftToRight", "RightToLeft" }),
        ["Keyboard"] = new(EditorType.Enum, "Behavior",
            EnumValues: new[] { "Default", "Chat", "Email", "Numeric", "Plain", "Telephone", "Text", "Url" }),
        ["AutomationId"] = new(EditorType.Text, "Behavior", SortOrder: 0),
        ["Text"] = new(EditorType.Text, "Appearance", SortOrder: 0),
    };

    private static readonly string[] CommonProperties = PropertyRegistry.Keys.ToArray();

    private static readonly string[] GroupOrder = new[] { "Appearance", "Layout", "Behavior", "Transform", "Other" };

    private static PropertyMeta GetMeta(string propName)
        => PropertyRegistry.TryGetValue(propName, out var meta) ? meta : new PropertyMeta(EditorType.Text, "Other");

    private static bool IsDefaultValue(string? value, string defaultValue)
    {
        if (string.IsNullOrEmpty(value)) return true;
        // Handle infinity comparisons
        if (defaultValue == "Infinity")
            return value.Contains("Infinity", StringComparison.OrdinalIgnoreCase)
                || (double.TryParse(value, out var v) && double.IsPositiveInfinity(v));
        // Numeric comparison
        if (double.TryParse(value, out var current) && double.TryParse(defaultValue, out var def))
            return Math.Abs(current - def) < 0.001;
        return string.Equals(value, defaultValue, StringComparison.OrdinalIgnoreCase);
    }

    // Resize state
    private double screenshotPaneWidth = 280;
    private double propsPaneWidth = 320;
    private bool isResizing;
    private string? resizingHandle;
    private double resizeStartX;
    private double resizeStartWidth;

    private void StartResize(MouseEventArgs e, string handle)
    {
        isResizing = true;
        resizingHandle = handle;
        resizeStartX = e.ClientX;
        resizeStartWidth = handle == "left" ? screenshotPaneWidth : propsPaneWidth;
    }

    private void OnResizeMove(MouseEventArgs e)
    {
        if (!isResizing || resizingHandle == null) return;

        var delta = e.ClientX - resizeStartX;

        if (resizingHandle == "left")
        {
            screenshotPaneWidth = Math.Clamp(resizeStartWidth + delta, 120, 600);
        }
        else
        {
            propsPaneWidth = Math.Clamp(resizeStartWidth - delta, 150, 600);
        }
    }

    private async Task StopResize(MouseEventArgs e)
    {
        isResizing = false;
        resizingHandle = null;
        await UpdateOverlayAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshTree();
        await RefreshScreenshot();
    }

    private async Task RefreshTree()
    {
        isLoadingTree = true;
        StateHasChanged();

        var previousSelected = selectedElementId;

        try
        {
            treeItems = await Client.GetTreeAsync();

            // Always expand all nodes
            expandedNodes.Clear();
            AddAllNodeIds(treeItems);

            // Re-select previous element
            if (previousSelected != null)
            {
                selectedElement = FindElement(treeItems, previousSelected);
                if (selectedElement == null)
                    selectedElementId = null;
            }
        }
        catch { }
        finally
        {
            isLoadingTree = false;
            StateHasChanged();
        }

        // Keep screenshot in sync with tree (avoid recursion via flag)
        if (!_syncingRefresh)
        {
            _syncingRefresh = true;
            try { await RefreshScreenshot(); }
            finally { _syncingRefresh = false; }
        }
    }

    private DevFlowElementInfo? FindElement(List<DevFlowElementInfo> items, string id)
    {
        foreach (var item in items)
        {
            if (item.Id == id) return item;
            if (item.Children?.Count > 0)
            {
                var found = FindElement(item.Children, id);
                if (found != null) return found;
            }
        }
        return null;
    }

    private async Task RefreshScreenshot(int? window = null)
    {
        try
        {
            var bytes = await Client.GetScreenshotAsync(window: window ?? selectedWindowIndex);
            screenshotData = bytes != null ? Convert.ToBase64String(bytes) : null;
            StateHasChanged();
            await UpdateOverlayAsync();
        }
        catch { }

        // Keep tree in sync with screenshot (avoid recursion via flag)
        if (!_syncingRefresh)
        {
            _syncingRefresh = true;
            try { await RefreshTree(); }
            finally { _syncingRefresh = false; }
        }
    }

    // --- Inspect Mode: Screenshot click → element selection ---

    private record ImageDimensions(double Width, double Height, double NaturalWidth, double NaturalHeight, double Left, double Top);

    private async Task CopyHitTestDebug()
    {
        if (hitTestDebugInfo != null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", hitTestDebugInfo);
    }

    private async Task OnScreenshotClick(MouseEventArgs e)
    {
        if (!inspectMode || treeItems.Count == 0)
            return;

        try
        {
            // Get image element dimensions and position via JS
            var dims = await JS.InvokeAsync<ImageDimensions>("eval",
                "(function() { var img = document.querySelector('.screenshot-img');" +
                "if (!img) return null;" +
                "var r = img.getBoundingClientRect();" +
                "return { width: r.width, height: r.height, naturalWidth: img.naturalWidth, naturalHeight: img.naturalHeight, left: r.left, top: r.top }; })()");

            if (dims == null || dims.NaturalWidth <= 0 || dims.NaturalHeight <= 0)
            {
                if (hitTestDebug) { hitTestDebugInfo = $"No dims: {(dims == null ? "null" : $"natW={dims.NaturalWidth}")}"; StateHasChanged(); }
                return;
            }

            // Use clientX/Y minus image rect to get position relative to the image element
            // (e.OffsetX/Y can be relative to wrapper div instead of img, causing wrong coordinates)
            var imgAspect = dims.NaturalWidth / dims.NaturalHeight;
            var boxAspect = dims.Width / dims.Height;
            double actW, actH, offX, offY;
            if (imgAspect > boxAspect)
            {
                actW = dims.Width; actH = dims.Width / imgAspect;
                offX = 0; offY = (dims.Height - actH) / 2;
            }
            else
            {
                actH = dims.Height; actW = dims.Height * imgAspect;
                offX = (dims.Width - actW) / 2; offY = 0;
            }

            // Click position within the actual image content, using clientX/Y for unambiguous mapping
            var mx = e.ClientX - dims.Left - offX;
            var my = e.ClientY - dims.Top - offY;

            if (hitTestDebug)
            {
                hitTestDebugInfo = $"client=({e.ClientX:F0},{e.ClientY:F0}) imgRect=({dims.Left:F0},{dims.Top:F0},{dims.Width:F0}×{dims.Height:F0}) mx=({mx:F1},{my:F1}) actW={actW:F0} nat={dims.NaturalWidth:F0}×{dims.NaturalHeight:F0}";
                StateHasChanged();
            }

            if (mx < 0 || my < 0 || mx > actW || my > actH)
            {
                if (hitTestDebug) { hitTestDebugInfo = $"Outside image: mx={mx:F0} my={my:F0} actW={actW:F0} actH={actH:F0}"; StateHasChanged(); }
                return;
            }

            // Compute DPI scale and window dimensions from windowBounds or fallback root bounds
            var (windowWidth, windowHeight, dpiScale) = GetWindowMetrics(dims.NaturalWidth, dims.NaturalHeight);
            if (windowWidth <= 0 || windowHeight <= 0)
            {
                if (hitTestDebug) { hitTestDebugInfo = "No window metrics available"; StateHasChanged(); }
                return;
            }

            // Map click to logical MAUI points (window coordinate space)
            // windowWidth/Height are in logical points; map directly from click position ratio
            var logicalX = (mx / actW) * windowWidth;
            var logicalY = (my / actH) * windowHeight;

            // Try server-side hit test first — API expects logical points (window coordinates)
            DevFlowElementInfo? hit = null;
            try
            {
                var hitResult = await Client.HitTestAsync(logicalX, logicalY, selectedWindowIndex);
                if (hitResult?.Elements.Count > 0)
                {
                    // API returns synthetic elements first, then MAUI elements — take the first match in our tree
                    string? hitNames = null;
                    if (hitTestDebug)
                        hitNames = string.Join("→", hitResult.Elements.Select(h => $"{h.Type}[{(FindElementById(treeItems, h.Id) != null ? "✓" : "✗")}]"));
                    foreach (var hitElement in hitResult.Elements)
                    {
                        var candidate = FindElementById(treeItems, hitElement.Id);
                        if (candidate != null)
                        {
                            // Enrich tree element with bounds from hit result if missing
                            if (candidate.WindowBounds == null && hitElement.WindowBounds != null)
                                candidate.WindowBounds = hitElement.WindowBounds;
                            if (candidate.Bounds == null && hitElement.Bounds != null)
                                candidate.Bounds = hitElement.Bounds;
                            hit = candidate;
                            if (hitTestDebug) { hitTestDebugInfo = $"HIT: {hit.Type} | sent=({logicalX:F1},{logicalY:F1}) win={windowWidth:F0}×{windowHeight:F0} dpi={dpiScale:F1} | {hitNames}"; StateHasChanged(); }
                            break;
                        }
                    }
                }
            }
            catch
            {
                // Server-side hit test not available; fall through to client-side
            }

            // Fall back to client-side hit test
            if (hit == null)
            {
                hit = HitTest(treeItems, logicalX, logicalY);
                if (hit != null && hitTestDebug) { hitTestDebugInfo = $"HIT (client): {hit.Type} at ({logicalX:F0},{logicalY:F0}) DPI={dpiScale:F1}"; StateHasChanged(); }
            }

            if (hit != null)
                await RevealAndSelectElement(hit);
            else if (hitTestDebug)
            {
                hitTestDebugInfo = $"No hit at ({logicalX:F0},{logicalY:F0}) DPI={dpiScale:F1} Win={windowWidth:F0}×{windowHeight:F0}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            if (hitTestDebug) { hitTestDebugInfo = $"ERROR: {ex.Message}"; StateHasChanged(); }
        }
    }

    /// <summary>
    /// Derives window dimensions (in logical points) and DPI scale from tree data.
    /// Prefers windowBounds (absolute window coords) when available; falls back to root bounds heuristic.
    /// </summary>
    private (double windowWidth, double windowHeight, double dpiScale) GetWindowMetrics(double screenshotPixelWidth, double screenshotPixelHeight)
    {
        // Find the largest windowBounds to determine full window dimensions
        var wb = FindLargestWindowBounds(treeItems);
        if (wb != null && wb.Width > 0 && wb.Height > 0)
        {
            var winW = wb.X + wb.Width;
            var winH = wb.Y + wb.Height;
            var scale = screenshotPixelWidth / winW;
            return (winW, winH, scale > 0 ? scale : 1);
        }

        // Fallback: find largest element bounds to approximate window size
        DevFlowBoundsInfo? best = null;
        double bestArea = 0;
        FindLargestBoundsRecursive(treeItems, ref best, ref bestArea);
        if (best != null)
        {
            var winW = best.X + best.Width;
            var winH = best.Y + best.Height;
            var scale = screenshotPixelWidth / winW;
            return (winW, winH, scale > 0 ? scale : 1);
        }

        return (0, 0, 1);
    }

    private DevFlowBoundsInfo? FindLargestWindowBounds(List<DevFlowElementInfo> items)
    {
        DevFlowBoundsInfo? best = null;
        double bestArea = 0;
        FindLargestWindowBoundsRecursive(items, ref best, ref bestArea);
        return best;
    }

    private void FindLargestWindowBoundsRecursive(List<DevFlowElementInfo> items, ref DevFlowBoundsInfo? best, ref double bestArea)
    {
        foreach (var item in items)
        {
            var wb = item.WindowBounds;
            if (wb != null && wb.Width > 0 && wb.Height > 0)
            {
                var area = wb.Width * wb.Height;
                if (area > bestArea)
                {
                    bestArea = area;
                    best = wb;
                }
            }
            if (item.Children?.Count > 0)
                FindLargestWindowBoundsRecursive(item.Children, ref best, ref bestArea);
        }
    }

    private void FindLargestBoundsRecursive(List<DevFlowElementInfo> items, ref DevFlowBoundsInfo? best, ref double bestArea)
    {
        foreach (var item in items)
        {
            if (item.Bounds != null && item.Bounds.Width > 0 && item.Bounds.Height > 0)
            {
                var area = item.Bounds.Width * item.Bounds.Height;
                if (area > bestArea)
                {
                    bestArea = area;
                    best = item.Bounds;
                }
            }
            if (item.Children?.Count > 0)
                FindLargestBoundsRecursive(item.Children, ref best, ref bestArea);
        }
    }

    private DevFlowElementInfo? HitTest(List<DevFlowElementInfo> items, double x, double y)
    {
        DevFlowElementInfo? best = null;
        HitTestRecursive(items, x, y, ref best);
        return best;
    }

    private void HitTestRecursive(List<DevFlowElementInfo> items, double x, double y, ref DevFlowElementInfo? best)
    {
        foreach (var item in items)
        {
            // Prefer windowBounds (absolute window coordinates)
            var wb = item.WindowBounds;
            if (wb != null && wb.Width > 0 && wb.Height > 0 && item.IsVisible &&
                x >= wb.X && x <= wb.X + wb.Width &&
                y >= wb.Y && y <= wb.Y + wb.Height)
            {
                best = item;
            }

            // Always recurse into children (hidden containers like Window/Shell have visible content)
            if (item.Children?.Count > 0)
                HitTestRecursive(item.Children, x, y, ref best);
        }
    }

    private DevFlowElementInfo? FindElementById(List<DevFlowElementInfo> items, string id)
    {
        foreach (var item in items)
        {
            if (item.Id == id) return item;
            if (item.Children?.Count > 0)
            {
                var found = FindElementById(item.Children, id);
                if (found != null) return found;
            }
        }
        return null;
    }

    private bool ExpandPathTo(List<DevFlowElementInfo> items, string targetId)
    {
        foreach (var item in items)
        {
            if (item.Id == targetId) return true;
            if (item.Children?.Count > 0 && ExpandPathTo(item.Children, targetId))
            {
                expandedNodes.Add(item.Id);
                return true;
            }
        }
        return false;
    }

    private (double x, double y, double w, double h)? GetAbsoluteBounds(DevFlowElementInfo element)
    {
        // Use windowBounds if available (absolute window coordinates from MauiDevFlow)
        var wb = element.WindowBounds;
        if (wb != null && wb.Width > 0 && wb.Height > 0)
            return (wb.X, wb.Y, wb.Width, wb.Height);

        // Fallback: accumulate relative bounds from ancestor path (older agents)
        if (element.Bounds == null || element.Bounds.Width <= 0) return null;
        var path = FindPathTo(treeItems, element.Id);
        if (path == null) return null;

        double absX = 0, absY = 0;
        DevFlowBoundsInfo? prevBounds = null;
        foreach (var ancestor in path)
        {
            var b = ancestor.Bounds;
            if (b != null && b.Width > 0 && b.Height > 0)
            {
                if (prevBounds == null ||
                    Math.Abs(b.X - prevBounds.X) > 0.5 || Math.Abs(b.Y - prevBounds.Y) > 0.5 ||
                    Math.Abs(b.Width - prevBounds.Width) > 0.5 || Math.Abs(b.Height - prevBounds.Height) > 0.5)
                {
                    absX += b.X;
                    absY += b.Y;
                }
                prevBounds = b;
            }
        }
        return (absX, absY, element.Bounds.Width, element.Bounds.Height);
    }

    private List<DevFlowElementInfo>? FindPathTo(List<DevFlowElementInfo> items, string targetId, List<DevFlowElementInfo>? path = null)
    {
        path ??= new();
        foreach (var item in items)
        {
            path.Add(item);
            if (item.Id == targetId) return path;
            if (item.Children?.Count > 0)
            {
                var result = FindPathTo(item.Children, targetId, path);
                if (result != null) return result;
            }
            path.RemoveAt(path.Count - 1);
        }
        return null;
    }

    private async Task RevealAndSelectElement(DevFlowElementInfo element)
    {
        ExpandPathTo(treeItems, element.Id);
        await SelectElement(element);
        locateElementId = element.Id; // show overlay for inspect-mode hits
        await UpdateOverlayAsync();
        StateHasChanged();

        // Scroll the selected tree node into view after render
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('.tree-node.selected')?.scrollIntoView({ block: 'center', behavior: 'smooth' })");
    }

