@page "/secrets/publish"
@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Pages.Forms
@inject IPublishProfileService ProfileService
@inject ISecretsPublisherService PublisherService
@inject IAlertService AlertService
@inject ILoggingService Logger
@inject IToolbarService ToolbarService
@inject IFormModalService FormModalService
@inject HybridFormBridgeHolder BridgeHolder
@inject ICloudSecretsService CloudSecretsService
@implements IDisposable

<h1><i class="fas fa-upload"></i> Publish Profiles</h1>

@if (CloudSecretsService.ActiveProvider is null)
{
    <div class="info-message">
        <i class="fas fa-info-circle"></i>
        Configure a cloud secrets provider in <a href="settings">Settings</a> to create and manage publish profiles.
    </div>
}
else if (isLoading)
{
    <div class="loading-inline"><i class="fas fa-spinner fa-spin"></i> Loading profiles...</div>
}
else if (!profiles.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="fas fa-upload"></i></div>
        <h2>No Publish Profiles</h2>
        <p>Create a publish profile to bundle Apple certificates, Android keystores, and secrets together for one-click CI/CD publishing.</p>
        <button class="btn btn-primary" @onclick="CreateProfile">
            <i class="fas fa-plus"></i> Create Profile
        </button>
    </div>
}
else
{
    <div class="profile-grid">
        @foreach (var profile in profiles)
        {
            <div class="profile-card">
                <div class="profile-header">
                    <div class="profile-title">@profile.Name</div>
                    <div class="profile-actions">
                        <button class="btn-icon" @onclick="@(() => EditProfile(profile))" title="Edit">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn-icon danger" @onclick="@(() => DeleteProfile(profile))" title="Delete">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(profile.Description))
                {
                    <div class="profile-description">@profile.Description</div>
                }

                <div class="profile-summary">
                    @if (profile.AppleConfigs.Any())
                    {
                        <span class="summary-badge apple">
                            <i class="fa-brands fa-apple"></i> @profile.AppleConfigs.Count Apple
                        </span>
                    }
                    @if (profile.AndroidConfigs.Any())
                    {
                        <span class="summary-badge android">
                            <i class="fa-brands fa-android"></i> @profile.AndroidConfigs.Count Android
                        </span>
                    }
                    @if (profile.SecretMappings.Any())
                    {
                        <span class="summary-badge secrets">
                            <i class="fa-solid fa-key"></i> @profile.SecretMappings.Count Secrets
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(profile.RepositoryFullName))
                {
                    <div class="profile-target">
                        <i class="fa-solid fa-arrow-right"></i> @profile.RepositoryFullName
                    </div>
                }

                <div class="profile-footer">
                    <button class="btn btn-primary btn-sm" @onclick="@(() => PublishProfile(profile))"
                            disabled="@(publishingProfileId == profile.Id)">
                        @if (publishingProfileId == profile.Id)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i> <span>Publishing...</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-upload"></i> <span>Publish</span>
                        }
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    List<PublishProfile> profiles = new();
    bool isLoading;
    string? publishingProfileId;

    protected override async Task OnInitializedAsync()
    {
        ToolbarService.SetItems(
            new ToolbarAction("create", "New Profile", "plus"),
            new ToolbarAction("refresh", "Refresh", "arrow.clockwise")
        );
        ToolbarService.SetSearch(null);
        ToolbarService.SetFilters();
        ToolbarService.ToolbarItemClicked += OnToolbarItemClicked;
        ProfileService.OnProfilesChanged += OnProfilesChanged;

        await CloudSecretsService.InitializeAsync();
        await LoadProfilesAsync();
    }

    void OnToolbarItemClicked(string actionId)
    {
        switch (actionId)
        {
            case "create":
                InvokeAsync(CreateProfile);
                break;
            case "refresh":
                ToolbarService.SetItemEnabled("refresh", false);
                InvokeAsync(async () =>
                {
                    try { await LoadProfilesAsync(); }
                    finally { ToolbarService.SetItemEnabled("refresh", true); }
                });
                break;
        }
    }

    void OnProfilesChanged() => InvokeAsync(async () =>
    {
        await LoadProfilesAsync();
        StateHasChanged();
    });

    async Task LoadProfilesAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            profiles = (await ProfileService.GetProfilesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Failed to load publish profiles: {ex}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    async Task CreateProfile()
    {
        var page = new Modals.PublishProfileEditorPage(BridgeHolder);
        var result = await FormModalService.ShowAsync<PublishProfile?>(page);

        if (result is not null)
        {
            await LoadProfilesAsync();
            await AlertService.ShowToastAsync($"Profile '{result.Name}' created.");
        }
    }

    async Task EditProfile(PublishProfile profile)
    {
        var page = new Modals.PublishProfileEditorPage(BridgeHolder, profile);
        var result = await FormModalService.ShowAsync<PublishProfile?>(page);

        if (result is not null)
        {
            await LoadProfilesAsync();
            await AlertService.ShowToastAsync($"Profile '{result.Name}' updated.");
        }
    }

    async Task DeleteProfile(PublishProfile profile)
    {
        var confirmed = await AlertService.ShowConfirmAsync(
            "Delete Profile",
            $"Are you sure you want to delete '{profile.Name}'? This cannot be undone.");

        if (confirmed)
        {
            await ProfileService.DeleteProfileAsync(profile.Id);
            await AlertService.ShowToastAsync($"Profile '{profile.Name}' deleted.");
        }
    }

    async Task PublishProfile(PublishProfile profile)
    {
        publishingProfileId = profile.Id;
        StateHasChanged();

        try
        {
            // Resolve all secrets
            var progress = new Progress<string>(msg =>
                InvokeAsync(StateHasChanged));
            var secrets = await ProfileService.ResolveSecretsAsync(profile, progress);

            if (secrets.Count == 0)
            {
                await AlertService.ShowAlertAsync("No Secrets", "No secrets could be resolved from this profile. Check that your certificates, keystores, and secrets are available.");
                return;
            }

            // If profile has a saved target, confirm and publish directly
            if (!string.IsNullOrEmpty(profile.PublisherId) && !string.IsNullOrEmpty(profile.RepositoryId))
            {
                var confirmed = await AlertService.ShowConfirmAsync(
                    "Publish Secrets",
                    $"Publish {secrets.Count} secret(s) to {profile.RepositoryFullName ?? profile.RepositoryId}?");

                if (confirmed)
                {
                    await PublisherService.PublishSecretsAsync(
                        profile.PublisherId,
                        profile.RepositoryId,
                        secrets,
                        new Progress<string>(msg => { }));

                    await AlertService.ShowToastAsync($"Published {secrets.Count} secret(s) to {profile.RepositoryFullName}.");
                }
            }
            else
            {
                // Open publish wizard to pick provider + repo
                var page = new Modals.PublishSecretsPage(BridgeHolder, secrets);
                var result = await FormModalService.ShowAsync<bool>(page);

                if (result)
                    await AlertService.ShowToastAsync($"Published {secrets.Count} secret(s) successfully.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Failed to publish profile: {ex}");
            await AlertService.ShowAlertAsync("Error", $"Failed to publish: {ex.Message}");
        }
        finally
        {
            publishingProfileId = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ToolbarService.ToolbarItemClicked -= OnToolbarItemClicked;
        ProfileService.OnProfilesChanged -= OnProfilesChanged;
    }
}

<style>
    h1 { margin-bottom: 1.25rem; font-size: 1.75rem; color: var(--text-primary); }

    .info-message {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        background: linear-gradient(135deg, rgba(66, 153, 225, 0.1), rgba(66, 153, 225, 0.05));
        border: none;
        border-radius: 0.75rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
    }
    .info-message i { color: var(--accent-primary); margin-top: 2px; }
    .info-message a { color: var(--accent-primary); text-decoration: none; }
    .info-message a:hover { text-decoration: underline; }

    .loading-inline {
        font-size: 0.875rem;
        color: var(--text-muted);
        padding: 0.5rem 0;
    }

    /* Empty state */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
        text-align: center;
    }

    .empty-icon {
        font-size: 3rem;
        color: var(--text-muted);
        opacity: 0.3;
        margin-bottom: 1rem;
    }

    .empty-state h2 {
        margin: 0 0 0.5rem;
        font-size: 1.25rem;
        color: var(--text-primary);
    }

    .empty-state p {
        margin: 0 0 1.5rem;
        font-size: 0.875rem;
        color: var(--text-muted);
        max-width: 400px;
    }

    /* Profile grid */
    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1rem;
    }

    .profile-card {
        background: var(--card-bg);
        border-radius: 0.75rem;
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .profile-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .profile-actions {
        display: flex;
        gap: 2px;
    }

    .btn-icon {
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: 0.25rem;
        color: var(--text-muted);
        font-size: 0.8125rem;
        transition: all 0.15s;
    }

    .btn-icon:hover {
        background: var(--bg-hover);
        color: var(--text-primary);
    }

    .btn-icon.danger:hover {
        color: var(--danger-color, #ef4444);
    }

    .profile-description {
        font-size: 0.8125rem;
        color: var(--text-muted);
    }

    .profile-summary {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .summary-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 0.75rem;
        font-size: 0.6875rem;
        font-weight: 500;
    }

    .summary-badge.apple {
        background: var(--status-info-bg, rgba(66, 153, 225, 0.1));
        color: var(--status-info-text, #2b6cb0);
    }

    .summary-badge.android {
        background: rgba(52, 168, 83, 0.1);
        color: #2d7d46;
    }

    .summary-badge.secrets {
        background: rgba(107, 70, 193, 0.1);
        color: #6b46c1;
    }

    .profile-target {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .profile-footer {
        margin-top: 4px;
        display: flex;
        justify-content: flex-end;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border: none;
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        font-weight: 500;
        cursor: pointer;
        transition: opacity 0.15s;
    }

    .btn-primary {
        background: var(--accent-primary, #3b82f6);
        color: white;
    }

    .btn-primary:hover { opacity: 0.9; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-sm {
        padding: 5px 12px;
        font-size: 0.75rem;
    }

    .btn i { font-size: 0.75rem; }

    /* Dark mode */
    :global(.theme-dark) .summary-badge.android { background: rgba(52, 168, 83, 0.15); color: #6fcf97; }
    :global(.theme-dark) .summary-badge.secrets { background: rgba(107, 70, 193, 0.15); color: #d6bcfa; }
</style>
