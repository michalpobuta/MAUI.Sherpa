@code {
    private string activeTab = "general";

    // General
    private string profileName = "";
    private string profileDescription = "";
    private string selectedPublisherId = "";
    private string selectedRepoId = "";
    private string selectedRepoFullName = "";
    private string repoSearch = "";
    private bool loadingRepos;
    private string? existingProfileId;

    // Apple
    private List<AppleConfigVM> appleConfigs = new();
    private List<AppleCertificate> certificates = new();
    private List<AppleProfile> profiles = new();
    private List<LocalSigningIdentity> localIdentities = new();
    private AppleConfigVM? appleWizardActive;

    // Android
    private List<AndroidConfigVM> androidConfigs = new();
    private List<AndroidKeystore> keystores = new();

    // Secrets
    private List<SecretMappingVM> secretMappings = new();
    private List<ManagedSecret> managedSecrets = new();
    private bool showSecretPicker;
    private string secretSearch = "";

    // Publishers
    private List<SecretsPublisherConfig> publishers = new();
    private List<PublisherRepository> repos = new();

    private IEnumerable<PublisherRepository> filteredRepos =>
        string.IsNullOrWhiteSpace(repoSearch)
            ? repos
            : repos.Where(r => r.FullName.Contains(repoSearch, StringComparison.OrdinalIgnoreCase)
                || (r.Description?.Contains(repoSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<ManagedSecret> filteredManagedSecrets
    {
        get
        {
            var existingKeys = secretMappings.Select(m => m.SourceKey).ToHashSet();
            var available = managedSecrets.Where(s => !existingKeys.Contains(s.Key));
            return string.IsNullOrWhiteSpace(secretSearch)
                ? available
                : available.Where(s => s.Key.Contains(secretSearch, StringComparison.OrdinalIgnoreCase)
                    || (s.Description?.Contains(secretSearch, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        bridge.SubmitRequested += OnSubmitRequested;

        // Load existing profile if editing
        if (bridge.Parameters.TryGetValue("Profile", out var profileObj) && profileObj is PublishProfile existing)
        {
            existingProfileId = existing.Id;
            profileName = existing.Name;
            profileDescription = existing.Description ?? "";
            selectedPublisherId = existing.PublisherId ?? "";
            selectedRepoId = existing.RepositoryId ?? "";
            selectedRepoFullName = existing.RepositoryFullName ?? "";

            appleConfigs = existing.AppleConfigs.Select(a => new AppleConfigVM
            {
                Label = a.Label,
                Platform = a.Platform,
                DistributionType = a.DistributionType,
                CertificateSerialNumber = a.CertificateSerialNumber,
                InstallerCertSerialNumber = a.InstallerCertSerialNumber,
                ProfileId = a.ProfileId,
                ProfileUuid = a.ProfileUuid,
                IncludeNotarization = a.IncludeNotarization,
                NotarizationAppleIdSecretKey = a.NotarizationAppleIdSecretKey,
                NotarizationPasswordSecretKey = a.NotarizationPasswordSecretKey,
                NotarizationTeamIdSecretKey = a.NotarizationTeamIdSecretKey,
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList()),
                IsComplete = true
            }).ToList();

            androidConfigs = existing.AndroidConfigs.Select(a => new AndroidConfigVM
            {
                Label = a.Label,
                KeystoreId = a.KeystoreId,
                KeyMappings = a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            }).ToList();

            secretMappings = existing.SecretMappings.Select(s => new SecretMappingVM
            {
                SourceKey = s.SourceKey,
                DestinationKeys = s.DestinationKeys.ToList()
            }).ToList();
        }

        ValidateForm();

        // Load data in parallel
        try
        {
            var publishersTask = PublisherService.GetPublishersAsync();
            var keystoresTask = KeystoreService.ListKeystoresAsync();
            var secretsTask = ManagedSecrets.ListAsync();

            publishers = (await publishersTask).ToList();
            keystores = (await keystoresTask).ToList();
            managedSecrets = (await secretsTask).ToList();

            // Load Apple data if an identity is available
            var identities = await AppleIdentityService.GetIdentitiesAsync();
            if (identities.Any())
            {
                var id = identities.First().Id;
                try
                {
                    var certResult = await Mediator.Request(new GetCertificatesRequest(id));
                    certificates = certResult.Result?.ToList() ?? new();
                    var profileResult = await Mediator.Request(new GetProfilesRequest(id));
                    profiles = profileResult.Result?.ToList() ?? new();
                }
                catch { }
            }

            // Load local signing identities for private key matching
            try { localIdentities = (await LocalCertService.GetSigningIdentitiesAsync()).ToList(); }
            catch { }

            // Load repos if publisher is selected
            if (!string.IsNullOrEmpty(selectedPublisherId))
                await LoadReposAsync();
        }
        catch { }

        StateHasChanged();
    }

    private async Task LoadReposAsync()
    {
        if (string.IsNullOrEmpty(selectedPublisherId)) return;
        loadingRepos = true;
        StateHasChanged();

        try
        {
            repos = (await PublisherService.ListRepositoriesAsync(selectedPublisherId)).ToList();
        }
        catch { repos = new(); }

        loadingRepos = false;
        StateHasChanged();
    }

    private void ValidateForm()
    {
        var bridge = BridgeHolder.Current;
        bridge?.SetValid(!string.IsNullOrWhiteSpace(profileName));
    }

    private Task OnSubmitRequested()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return Task.CompletedTask;

        var profile = new PublishProfile(
            Id: existingProfileId ?? Guid.NewGuid().ToString(),
            Name: profileName.Trim(),
            Description: string.IsNullOrWhiteSpace(profileDescription) ? null : profileDescription.Trim(),
            PublisherId: string.IsNullOrEmpty(selectedPublisherId) ? null : selectedPublisherId,
            RepositoryId: string.IsNullOrEmpty(selectedRepoId) ? null : selectedRepoId,
            RepositoryFullName: string.IsNullOrEmpty(selectedRepoFullName) ? null : selectedRepoFullName,
            AppleConfigs: appleConfigs.Select(a => new PublishProfileAppleConfig(
                a.Label,
                a.Platform,
                a.DistributionType,
                a.CertificateSerialNumber,
                a.InstallerCertSerialNumber,
                a.ProfileId,
                a.ProfileUuid,
                a.IncludeNotarization,
                a.NotarizationAppleIdSecretKey,
                a.NotarizationPasswordSecretKey,
                a.NotarizationTeamIdSecretKey,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            AndroidConfigs: androidConfigs.Select(a => new PublishProfileAndroidConfig(
                a.Label,
                a.KeystoreId,
                a.KeyMappings.ToDictionary(k => k.Key, k => k.Value.ToList())
            )).ToList(),
            SecretMappings: secretMappings.Select(s => new PublishProfileSecretMapping(
                s.SourceKey,
                s.DestinationKeys.ToList()
            )).ToList(),
            CreatedAt: existingProfileId is not null
                ? (BridgeHolder.Current?.Parameters.TryGetValue("Profile", out var p) == true && p is PublishProfile ep ? ep.CreatedAt : DateTime.UtcNow)
                : DateTime.UtcNow,
            UpdatedAt: DateTime.UtcNow
        );

        bridge.Result = profile;
        return Task.CompletedTask;
    }

    // Apple wizard helpers
    private void StartAppleWizard()
    {
        appleWizardActive = new AppleConfigVM();
    }

    private void EditAppleConfig(AppleConfigVM config)
    {
        config.WizardStep = 1;
        config.IsEditing = true;
        appleWizardActive = config;
    }

    private void CancelAppleWizard()
    {
        if (appleWizardActive is not null)
        {
            if (appleWizardActive.IsEditing)
            {
                appleWizardActive.IsEditing = false;
            }
            appleWizardActive = null;
        }
    }

    private void AppleWizardBack()
    {
        if (appleWizardActive is null) return;
        appleWizardActive.WizardStep = Math.Max(1, appleWizardActive.WizardStep - 1);
    }

    private void AppleWizardNext()
    {
        if (appleWizardActive is null || !CanAppleWizardProceed()) return;
        // When platform/distribution changes, auto-generate a label
        if (appleWizardActive.WizardStep == 2 && string.IsNullOrEmpty(appleWizardActive.Label))
        {
            appleWizardActive.Label = $"{appleWizardActive.PlatformLabel} {appleWizardActive.DistributionLabel}";
        }
        appleWizardActive.WizardStep = Math.Min(appleWizardActive.TotalSteps, appleWizardActive.WizardStep + 1);
    }

    private void FinishAppleWizard()
    {
        if (appleWizardActive is null || !CanAppleWizardProceed()) return;
        appleWizardActive.IsComplete = true;
        appleWizardActive.IsEditing = false;
        if (string.IsNullOrEmpty(appleWizardActive.Label))
            appleWizardActive.Label = $"{appleWizardActive.PlatformLabel} {appleWizardActive.DistributionLabel}";
        // Ensure key mappings are populated
        appleWizardActive.GetDefaultKeys();
        if (!appleConfigs.Contains(appleWizardActive))
            appleConfigs.Add(appleWizardActive);
        appleWizardActive = null;
        ValidateForm();
    }

    private bool CanAppleWizardProceed()
    {
        if (appleWizardActive is null) return false;
        return appleWizardActive.WizardStep switch
        {
            1 => appleWizardActive.Platform is not null,
            2 => appleWizardActive.DistributionType is not null,
            _ => true // cert, installer, profile, notarization are all optional
        };
    }

    private bool IsSigningCertCompatible(string certType)
    {
        if (appleWizardActive is null) return false;
        var ct = certType.ToUpperInvariant();
        return appleWizardActive.DistributionType switch
        {
            AppleDistributionType.Development => ct.Contains("DEVELOPMENT"),
            AppleDistributionType.AdHoc => ct.Contains("DISTRIBUTION") && !ct.Contains("DEVELOPER_ID"),
            AppleDistributionType.AppStore => ct.Contains("DISTRIBUTION") && !ct.Contains("DEVELOPER_ID"),
            AppleDistributionType.Direct => ct.Contains("DEVELOPER_ID_APPLICATION"),
            _ => false
        };
    }

    private bool IsProfileCompatible(string profileType)
    {
        if (appleWizardActive is null) return false;
        var pt = profileType.ToUpperInvariant();
        var platformMatch = appleWizardActive.Platform switch
        {
            ApplePlatformType.iOS => pt.StartsWith("IOS_"),
            ApplePlatformType.MacCatalyst => pt.StartsWith("MAC_CATALYST_"),
            ApplePlatformType.macOS => pt.StartsWith("MAC_APP_"),
            _ => false
        };
        if (!platformMatch) return false;
        return appleWizardActive.DistributionType switch
        {
            AppleDistributionType.Development => pt.Contains("DEVELOPMENT"),
            AppleDistributionType.AdHoc => pt.Contains("ADHOC"),
            AppleDistributionType.AppStore => pt.Contains("STORE"),
            AppleDistributionType.Direct => pt.Contains("DIRECT"),
            _ => false
        };
    }

    private bool HasPrivateKey(AppleCertificate cert)
        => localIdentities.Any(li =>
            (li.SerialNumber is not null && li.SerialNumber.Equals(cert.SerialNumber, StringComparison.OrdinalIgnoreCase)) ||
            li.CommonName.Contains(cert.Name, StringComparison.OrdinalIgnoreCase) ||
            cert.Name.Contains(li.CommonName, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AppleCertificate> FilteredSigningCerts =>
        certificates.Where(c => IsSigningCertCompatible(c.CertificateType) && c.ExpirationDate > DateTime.UtcNow)
                    .OrderByDescending(c => HasPrivateKey(c));

    private IEnumerable<AppleCertificate> FilteredInstallerCerts =>
        certificates.Where(c => c.CertificateType.Contains("INSTALLER", StringComparison.OrdinalIgnoreCase) && c.ExpirationDate > DateTime.UtcNow)
                    .OrderByDescending(c => HasPrivateKey(c));

    private IEnumerable<AppleProfile> FilteredProfiles =>
        profiles.Where(p => p.State == "ACTIVE" && IsProfileCompatible(p.ProfileType));

    private IEnumerable<(AppleDistributionType Type, string Name, string Description, string Icon)> GetAvailableDistributionTypes()
    {
        if (appleWizardActive is null) yield break;
        yield return (AppleDistributionType.Development, "Development", "Build and test on registered devices", "fa-solid fa-code");
        if (appleWizardActive.Platform == ApplePlatformType.iOS)
            yield return (AppleDistributionType.AdHoc, "Ad Hoc", "Distribute to specific registered devices", "fa-solid fa-users");
        yield return (AppleDistributionType.AppStore, "App Store / TestFlight", "Submit to the App Store or TestFlight", "fa-brands fa-app-store");
        if (appleWizardActive.Platform != ApplePlatformType.iOS)
            yield return (AppleDistributionType.Direct, "Direct Distribution", "Distribute outside the App Store (notarized)", "fa-solid fa-box-open");
    }

    // Android helpers
    private void AddAndroidConfig()
    {
        androidConfigs.Add(new AndroidConfigVM { Label = "PlayStore" });
    }

    // Secrets helpers
    private void AddSecretMapping(string sourceKey)
    {
        if (secretMappings.Any(m => m.SourceKey == sourceKey)) return;
        secretMappings.Add(new SecretMappingVM
        {
            SourceKey = sourceKey,
            DestinationKeys = new List<string> { sourceKey }
        });
        showSecretPicker = false;
    }

    // Key mapping helpers
    private void AddDestination(Dictionary<string, List<string>> mappings, string defaultKey)
    {
        if (!mappings.ContainsKey(defaultKey))
            mappings[defaultKey] = new List<string> { defaultKey };
        mappings[defaultKey].Add(defaultKey + "_" + (mappings[defaultKey].Count + 1));
    }

    private void RemoveDestination(Dictionary<string, List<string>> mappings, string defaultKey, string dest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            list.Remove(dest);
            if (list.Count == 0)
                mappings.Remove(defaultKey);
        }
    }

    private void UpdateDestination(Dictionary<string, List<string>> mappings, string defaultKey, string oldDest, string newDest)
    {
        if (mappings.TryGetValue(defaultKey, out var list))
        {
            var idx = list.IndexOf(oldDest);
            if (idx >= 0 && !string.IsNullOrWhiteSpace(newDest))
                list[idx] = newDest;
        }
    }

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is not null)
            bridge.SubmitRequested -= OnSubmitRequested;
    }

    // View models for mutable editing
    private class AppleConfigVM
    {
        public string Label { get; set; } = "";
        public ApplePlatformType? Platform { get; set; }
        public AppleDistributionType? DistributionType { get; set; }
        public string? CertificateSerialNumber { get; set; }
        public string? InstallerCertSerialNumber { get; set; }
        public string? ProfileId { get; set; }
        public string? ProfileUuid { get; set; }
        public bool IncludeNotarization { get; set; }
        public string? NotarizationAppleIdSecretKey { get; set; }
        public string? NotarizationPasswordSecretKey { get; set; }
        public string? NotarizationTeamIdSecretKey { get; set; }
        public Dictionary<string, List<string>> KeyMappings { get; set; } = new();

        // Wizard state
        public int WizardStep { get; set; } = 1;
        public bool IsEditing { get; set; }
        public bool IsComplete { get; set; }

        public bool NeedsInstallerStep =>
            DistributionType == AppleDistributionType.Direct &&
            (Platform == ApplePlatformType.MacCatalyst || Platform == ApplePlatformType.macOS);

        public bool NeedsProfileStep =>
            !(Platform == ApplePlatformType.macOS && DistributionType == AppleDistributionType.Direct);

        public bool NeedsNotarizationStep =>
            DistributionType == AppleDistributionType.Direct;

        public int TotalSteps
        {
            get
            {
                int steps = 3; // platform + distribution + signing cert
                if (NeedsInstallerStep) steps++;
                if (NeedsProfileStep) steps++;
                if (NeedsNotarizationStep) steps++;
                return steps;
            }
        }

        public string GetStepLabel(int step)
        {
            int s = 0;
            s++; if (step == s) return "Platform";
            s++; if (step == s) return "Distribution";
            s++; if (step == s) return "Certificate";
            if (NeedsInstallerStep) { s++; if (step == s) return "Installer"; }
            if (NeedsProfileStep) { s++; if (step == s) return "Profile"; }
            if (NeedsNotarizationStep) { s++; if (step == s) return "Notarization"; }
            return "";
        }

        public string PlatformLabel => Platform switch
        {
            ApplePlatformType.iOS => "iOS",
            ApplePlatformType.MacCatalyst => "Mac Catalyst",
            ApplePlatformType.macOS => "macOS",
            _ => ""
        };

        public string DistributionLabel => DistributionType switch
        {
            AppleDistributionType.Development => "Development",
            AppleDistributionType.AdHoc => "Ad Hoc",
            AppleDistributionType.AppStore => "App Store",
            AppleDistributionType.Direct => "Direct",
            _ => ""
        };

        public List<string> GetDefaultKeys()
        {
            var keys = new List<string>();
            var platLabel = Platform switch
            {
                ApplePlatformType.iOS => "IOS",
                ApplePlatformType.MacCatalyst => "MACCATALYST",
                ApplePlatformType.macOS => "MACOS",
                _ => Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_')
            };
            var distLabel = DistributionType switch
            {
                AppleDistributionType.Development => "DEV",
                AppleDistributionType.AdHoc => "ADHOC",
                AppleDistributionType.AppStore => "APPSTORE",
                AppleDistributionType.Direct => "DIRECT",
                _ => ""
            };
            var prefix = $"APPLE_{platLabel}_{distLabel}";

            if (!string.IsNullOrEmpty(CertificateSerialNumber))
            {
                keys.Add($"{prefix}_CERTIFICATE_P12");
                keys.Add($"{prefix}_CERTIFICATE_PASSWORD");
            }
            if (!string.IsNullOrEmpty(InstallerCertSerialNumber))
            {
                keys.Add($"{prefix}_INSTALLER_P12");
                keys.Add($"{prefix}_INSTALLER_PASSWORD");
            }
            if (!string.IsNullOrEmpty(ProfileId))
                keys.Add($"{prefix}_PROFILE");
            if (IncludeNotarization)
            {
                keys.Add("APPLE_NOTARIZATION_APPLE_ID");
                keys.Add("APPLE_NOTARIZATION_PASSWORD");
                keys.Add("APPLE_NOTARIZATION_TEAM_ID");
            }

            foreach (var key in keys)
            {
                if (!KeyMappings.ContainsKey(key))
                    KeyMappings[key] = new List<string> { key };
            }
            foreach (var k in KeyMappings.Keys.ToList())
            {
                if (!keys.Contains(k))
                    KeyMappings.Remove(k);
            }
            return keys;
        }
    }

    private class AndroidConfigVM
    {
        public string Label { get; set; } = "";
        public string? KeystoreId { get; set; }
        public Dictionary<string, List<string>> KeyMappings { get; set; } = new();

        public bool ShowKeystorePicker => KeystoreId is null;

        public bool HasAnyItems => !string.IsNullOrEmpty(KeystoreId);

        public List<string> GetDefaultKeys()
        {
            var keys = new List<string>();
            var label = Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_');
            if (!string.IsNullOrEmpty(KeystoreId))
            {
                keys.Add($"ANDROID_{label}_KEYSTORE");
                keys.Add($"ANDROID_{label}_KEYSTORE_PASSWORD");
                keys.Add($"ANDROID_{label}_KEY_ALIAS");
                keys.Add($"ANDROID_{label}_KEY_PASSWORD");
            }

            foreach (var key in keys)
            {
                if (!KeyMappings.ContainsKey(key))
                    KeyMappings[key] = new List<string> { key };
            }

            foreach (var k in KeyMappings.Keys.ToList())
            {
                if (!keys.Contains(k))
                    KeyMappings.Remove(k);
            }

            return keys;
        }
    }

    private class SecretMappingVM
    {
        public string SourceKey { get; set; } = "";
        public List<string> DestinationKeys { get; set; } = new();
    }
}
