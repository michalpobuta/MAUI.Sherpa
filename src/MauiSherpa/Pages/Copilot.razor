    private async Task Connect()
    {
        isConnecting = true;
        StateHasChanged();

        try
        {
            await CopilotService.ConnectAsync();
            await CopilotService.StartSessionAsync(systemPrompt: _systemPrompt);
        }
        catch (Exception ex)
        {
