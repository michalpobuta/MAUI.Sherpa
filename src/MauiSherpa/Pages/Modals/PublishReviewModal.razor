@code {
    private int step = 1;
    private Dictionary<string, string> secretsDict = new();
    private List<string> secretKeys = new();
    private Dictionary<string, bool> checkedSecrets = new();
    private PublishProfile? profile;

    // Resolving state
    private bool isResolving = true;
    private string resolvingStatus = "Preparing...";
    private string? resolveError;
    private List<string> resolveWarnings = new();

    private List<DestinationVM> destinations = new();
    private List<SecretsPublisherConfig> allPublishers = new();

    // Add destination inline picker
    private bool showAddDestination;
    private int addDestStep; // 0 = pick provider, 1 = pick repo
    private SecretsPublisherConfig? addDestPublisher;
    private string addDestRepoSearch = "";
    private bool addDestLoadingRepos;
    private List<PublisherRepository> addDestRepos = new();

    // Publish state
    private bool isPublishing;
    private bool publishComplete;

    private int selectedSecretCount => checkedSecrets.Count(kv => kv.Value);

    private IEnumerable<PublisherRepository> addDestFilteredRepos =>
        string.IsNullOrWhiteSpace(addDestRepoSearch)
            ? addDestRepos
            : addDestRepos.Where(r =>
                r.FullName.Contains(addDestRepoSearch, StringComparison.OrdinalIgnoreCase)
                || (r.Description?.Contains(addDestRepoSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        if (bridge.Parameters.TryGetValue("Profile", out var profileObj) && profileObj is PublishProfile p)
            profile = p;

        bridge.SubmitRequested += OnSubmitRequested;
        bridge.BackRequested += OnBackRequested;
        bridge.NextRequested += OnNextRequested;

        // Resolve secrets inside the dialog
        isResolving = true;
        resolvingStatus = "Resolving secrets from profile...";
        bridge.SetWizardState(showBack: false, showNext: false, showSubmit: false, canProceed: false, submitText: "Publish");
        StateHasChanged();

        try
        {
            var progress = new Progress<string>(msg =>
            {
                resolvingStatus = msg;
                InvokeAsync(StateHasChanged);
            });

            secretsDict = await ProfileService.ResolveSecretsAsync(profile!, progress);

            // Check for partial failures — items that were configured but didn't resolve
            foreach (var apple in profile!.AppleConfigs)
            {
                var label = apple.Label.ToUpperInvariant().Replace(' ', '_').Replace('-', '_');
                if (!string.IsNullOrEmpty(apple.CertificateSerialNumber)
                    && !secretsDict.Keys.Any(k => k.Contains(label) && k.Contains("CERTIFICATE")))
                    resolveWarnings.Add($"Certificate for \"{apple.Label}\" could not be fetched");
                if (!string.IsNullOrEmpty(apple.ProfileId)
                    && !secretsDict.Keys.Any(k => k.Contains(label) && k.Contains("PROVISIONING")))
                    resolveWarnings.Add($"Provisioning profile for \"{apple.Label}\" could not be fetched");
            }

            if (secretsDict.Count == 0)
            {
                resolveError = "No secrets could be resolved from this profile. Check that your certificates, keystores, and secrets are available.";
                isResolving = false;
                StateHasChanged();
                return;
            }
        }
        catch (Exception ex)
        {
            resolveError = $"Failed to resolve secrets: {ex.Message}";
            Logger.LogError($"Failed to resolve secrets: {ex}");
            isResolving = false;
            StateHasChanged();
            return;
        }

        secretKeys = secretsDict.Keys.OrderBy(k => k).ToList();
        checkedSecrets = secretKeys.ToDictionary(k => k, _ => true);

        // Load profile publishers as destinations
        if (profile?.Publishers?.Any() == true)
        {
            destinations = profile.Publishers.Select(pub => new DestinationVM
            {
                PublisherId = pub.PublisherId,
                PublisherName = pub.PublisherName,
                ProviderId = pub.ProviderId,
                RepositoryId = pub.RepositoryId,
                RepositoryFullName = pub.RepositoryFullName,
                Checked = true
            }).ToList();
        }
        // Legacy single publisher fallback
        else if (!string.IsNullOrEmpty(profile?.PublisherId) && !string.IsNullOrEmpty(profile?.RepositoryId))
        {
            try
            {
                var pubConfig = await PublisherService.GetPublisherAsync(profile.PublisherId);
                if (pubConfig is not null)
                {
                    destinations.Add(new DestinationVM
                    {
                        PublisherId = pubConfig.Id,
                        PublisherName = pubConfig.Name,
                        ProviderId = pubConfig.ProviderId,
                        RepositoryId = profile.RepositoryId,
                        RepositoryFullName = profile.RepositoryFullName ?? profile.RepositoryId,
                        Checked = true
                    });
                }
            }
            catch { }
        }

        allPublishers = (await PublisherService.GetPublishersAsync()).ToList();

        isResolving = false;

        UpdateWizardState();
    }

    private void UpdateWizardState()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is null) return;

        bool canProceed = step switch
        {
            1 => checkedSecrets.Any(kv => kv.Value),
            2 => destinations.Any(d => d.Checked),
            3 => publishComplete,
            _ => false
        };

        bridge.SetWizardState(
            showBack: step > 1 && !isPublishing && !publishComplete,
            showNext: step < 3 && !isPublishing,
            showSubmit: (step == 2 && !isPublishing) || publishComplete,
            canProceed: canProceed,
            submitText: publishComplete ? "Done" : "Publish"
        );
    }

    private Task OnNextRequested()
    {
        if (step == 1 && checkedSecrets.Any(kv => kv.Value))
        {
            step = 2;
            showAddDestination = false;
        }
        UpdateWizardState();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnBackRequested()
    {
        if (step > 1 && !isPublishing)
        {
            step--;
            UpdateWizardState();
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task OnSubmitRequested()
    {
        if (publishComplete)
        {
            var bridge = BridgeHolder.Current;
            if (bridge is not null)
                bridge.Result = true;
            return;
        }

        if (step != 2) return;

        var checkedDests = destinations.Where(d => d.Checked).ToList();
        if (!checkedDests.Any()) return;

        step = 3;
        isPublishing = true;
        UpdateWizardState();
        await InvokeAsync(StateHasChanged);

        var selectedSecrets = secretsDict
            .Where(kv => checkedSecrets.GetValueOrDefault(kv.Key, false))
            .ToDictionary(kv => kv.Key, kv => kv.Value);

        foreach (var dest in checkedDests)
        {
            dest.Status = PublishStatus.InProgress;
            dest.StatusMessage = $"Publishing {selectedSecrets.Count} secret(s)...";
            await InvokeAsync(StateHasChanged);

            try
            {
                var progress = new Progress<string>(msg =>
                {
                    dest.StatusMessage = msg;
                    InvokeAsync(StateHasChanged);
                });

                await PublisherService.PublishSecretsAsync(
                    dest.PublisherId, dest.RepositoryId, selectedSecrets, progress);

                dest.Status = PublishStatus.Success;
                dest.StatusMessage = $"{selectedSecrets.Count} secret(s) published successfully";
            }
            catch (Exception ex)
            {
                dest.Status = PublishStatus.Error;
                dest.StatusMessage = $"Error: {ex.Message}";
                Logger.LogError($"Failed to publish to {dest.RepositoryFullName}: {ex}");
            }

            await InvokeAsync(StateHasChanged);
        }

        isPublishing = false;
        publishComplete = true;
        UpdateWizardState();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleAllSecrets()
    {
        var allChecked = checkedSecrets.All(kv => kv.Value);
        foreach (var key in secretKeys)
            checkedSecrets[key] = !allChecked;
        UpdateWizardState();
    }

    private async Task SelectAddPublisher(SecretsPublisherConfig pub)
    {
        addDestPublisher = pub;
        addDestStep = 1;
        addDestRepoSearch = "";
        addDestRepos = new();
        addDestLoadingRepos = true;
        StateHasChanged();

        try
        {
            var result = await Mediator.Request(new ListPublisherRepositoriesRequest(pub.Id));
            addDestRepos = result.Result?.ToList() ?? new();
        }
        catch { addDestRepos = new(); }

        addDestLoadingRepos = false;
        StateHasChanged();
    }

    private void AddNewDestination(PublisherRepository repo)
    {
        if (addDestPublisher is null) return;
        if (destinations.Any(d => d.PublisherId == addDestPublisher.Id && d.RepositoryId == repo.Id))
            return;

        destinations.Add(new DestinationVM
        {
            PublisherId = addDestPublisher.Id,
            PublisherName = addDestPublisher.Name,
            ProviderId = addDestPublisher.ProviderId,
            RepositoryId = repo.Id,
            RepositoryFullName = repo.FullName,
            Checked = true
        });

        showAddDestination = false;
        addDestStep = 0;
        addDestPublisher = null;
        UpdateWizardState();
    }

    private string GetProviderIcon(string providerId) => providerId switch
    {
        "github" => "fa-brands fa-github",
        "gitlab" => "fa-brands fa-gitlab",
        "gitea" => "fa-solid fa-mug-hot",
        "azuredevops" or "azure-devops" => "fa-brands fa-microsoft",
        _ => "fa-solid fa-cloud"
    };

    public void Dispose()
    {
        var bridge = BridgeHolder.Current;
        if (bridge is not null)
        {
            bridge.SubmitRequested -= OnSubmitRequested;
            bridge.BackRequested -= OnBackRequested;
            bridge.NextRequested -= OnNextRequested;
        }
    }

    private class DestinationVM
    {
        public string PublisherId { get; set; } = "";
        public string PublisherName { get; set; } = "";
        public string ProviderId { get; set; } = "";
        public string RepositoryId { get; set; } = "";
        public string RepositoryFullName { get; set; } = "";
        public bool Checked { get; set; } = true;
        public PublishStatus Status { get; set; } = PublishStatus.Pending;
        public string StatusMessage { get; set; } = "";
    }

    private enum PublishStatus { Pending, InProgress, Success, Error }
}
