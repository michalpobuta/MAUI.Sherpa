@using MauiSherpa.Core.Interfaces
@using MauiSherpa.Core.Services
@using MauiSherpa.Services
@using MauiSherpa.Pages.Forms
@using Microsoft.Maui.Controls
@inject ProcessModalService ModalService
@inject IProcessExecutionService ProcessService
@inject ICopilotContextService CopilotContext
@inject IJSRuntime JS
@inject ProgressBridgeHolder BridgeHolder
@implements IDisposable

@if (IsVisible)
{
    <div class="process-content" id="process-modal">
        @if (CurrentView == ModalView.Confirmation)
        {
            <div class="confirmation-view">
                @if (!string.IsNullOrEmpty(Request?.Description))
                {
                    <p class="description">@Request.Description</p>
                }

                <div class="command-preview">
                    <label>Command to execute:</label>
                    <div class="command-box">
                        <code>@Request?.CommandLine</code>
                    </div>
                </div>

                @if (Request?.RequiresElevation == true)
                {
                    <div class="elevation-warning">
                        <i class="fas fa-exclamation-triangle warning-icon"></i>
                        <span>This command requires administrator privileges. You may be prompted for your password.</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Request?.WorkingDirectory))
                {
                    <div class="working-dir">
                        <label>Working directory:</label>
                        <code>@Request.WorkingDirectory</code>
                    </div>
                }
            </div>
        }
        else if (CurrentView == ModalView.Running)
        {
            <div class="running-view">
                <div class="terminal-wrapper">
                    <div class="terminal-container" id="process-terminal"></div>
                </div>
                <div class="process-status-bar">
                    <div class="process-status-info">
                        <i class="fas fa-spinner fa-spin"></i>
                        <span class="process-status-text">Running... @ElapsedTime</span>
                    </div>
                    <div class="process-controls">
                        <button class="btn btn-warning btn-sm" @onclick="HandleCancel" disabled="@(!CanCancel)">
                            Cancel
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="HandleKill" disabled="@(!CanKill)">
                            Force Kill
                        </button>
                    </div>
                </div>
            </div>
        }
        else if (CurrentView == ModalView.Completed)
        {
            <div class="completed-view">
                <div class="terminal-wrapper completed">
                    <div class="terminal-header">
                        <span>Output</span>
                        <button class="btn-icon" @onclick="CopyOutput" title="Copy output"><i class="fas fa-copy"></i></button>
                    </div>
                    <div class="terminal-container" id="process-terminal"></div>
                </div>
                <div class="result-status @GetResultClass()">
                    <i class="fas @GetResultIcon() result-icon"></i>
                    <span class="result-text">@GetResultText()</span>
                </div>
                <div class="result-details">
                    <div class="detail-item">
                        <label>Exit code:</label>
                        <span class="@(Result?.ExitCode == 0 ? "success" : "error")">@Result?.ExitCode</span>
                    </div>
                    <div class="detail-item">
                        <label>Duration:</label>
                        <span>@Result?.Duration.ToString(@"mm\:ss\.fff")</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .process-content {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 1.25rem;
        overflow: auto;
    }

    /* Confirmation View */
    .confirmation-view .description {
        color: #4a5568;
        margin-bottom: 1rem;
    }

    .command-preview {
        margin-bottom: 1rem;
    }

    .command-preview label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #718096;
        margin-bottom: 0.5rem;
    }

    .command-box {
        background: #1e1e1e;
        border-radius: var(--card-radius, 1rem);
        padding: 1rem;
        overflow-x: auto;
    }

    .command-box code {
        font-family: "SF Mono", Menlo, Monaco, monospace;
        font-size: 0.8125rem;
        color: #4ec9b0;
        white-space: pre-wrap;
        word-break: break-all;
        background: transparent;
    }

    .elevation-warning {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.75rem 1rem;
        background: #fffbeb;
        border-radius: var(--card-radius, 1rem);
        margin-bottom: 1rem;
    }

    .elevation-warning .warning-icon { font-size: 1.125rem; }
    .elevation-warning span { color: #92400e; font-size: 0.875rem; }

    .working-dir {
        font-size: 0.8125rem;
        color: #718096;
    }

    .working-dir label {
        font-weight: 500;
        margin-right: 0.5rem;
    }

    .working-dir code {
        font-family: monospace;
        background: #f7fafc;
        padding: 2px 0.375rem;
        border-radius: 0.25rem;
    }

    /* Running View */
    .running-view {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

    .process-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.625rem 0.875rem;
        background: var(--bg-tertiary, #f7fafc);
        border-radius: var(--card-radius, 1rem);
        margin-top: 0.75rem;
    }

    .process-status-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .process-status-text { color: #4a5568; font-weight: 500; }

    .process-controls { display: flex; gap: 0.5rem; }

    .terminal-wrapper {
        flex: 1;
        min-height: 150px;
        background: #1e1e1e;
        border-radius: var(--card-radius, 1rem);
        overflow: hidden;
        position: relative;
    }

    .terminal-wrapper.completed {
        min-height: 100px;
        max-height: 300px;
        overflow-y: auto;
    }

    .terminal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0.75rem;
        background: #2d2d2d;
        border-bottom: 1px solid #3e3e3e;
        font-size: 0.75rem;
        color: #a0aec0;
    }

    .terminal-container {
        height: calc(100% - 35px);
        padding: 0.5rem;
        background: #1e1e1e;
    }

    .terminal-wrapper:not(.completed) .terminal-container {
        height: 100%;
        background: #1e1e1e;
    }

    .terminal-container .xterm {
        padding: 12px;
    }

    /* Completed View */
    .completed-view { display: flex; flex-direction: column; gap: 1rem; overflow: hidden; flex: 1; min-height: 0; }

    .result-status {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        border-radius: var(--card-radius, 1rem);
    }

    .result-status.success { background: #f0fff4; }
    .result-status.error { background: #fff5f5; }
    .result-status.cancelled { background: #fffbeb; }

    .result-icon { font-size: 1.5rem; }
    .result-text { font-weight: 600; font-size: 1rem; }

    .result-status.success .result-text { color: #276749; }
    .result-status.error .result-text { color: #c53030; }
    .result-status.cancelled .result-text { color: #975a16; }

    .result-details {
        display: flex;
        gap: 1.5rem;
    }

    .detail-item label {
        font-size: 0.8125rem;
        color: #718096;
        margin-right: 0.375rem;
    }

    .detail-item span { font-weight: 500; }
    .detail-item span.success { color: #38a169; }
    .detail-item span.error { color: #e53e3e; }

    .btn-copilot { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; display: inline-flex; align-items: center; gap: 0.5rem; }
    .btn-copilot:hover:not(:disabled) { background: linear-gradient(135deg, #4f46e5, #7c3aed); }

    .btn-icon {
        background: none;
        border: none;
